{{ 'section-results.css' | asset_url | stylesheet_tag }}
{{ 'component-rte.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .volu-results-section {
    background: #fff5f8;
    padding: 70px 20px;
    text-align: center;
  }
  /* Hide big cards on mobile */
  @media (max-width: 749px) {
    .volu-results-cards {
      display: none;
    }
    /* Simple mobile stats */
    .volu-results-mobile {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin: 0 auto 30px;
      max-width: 400px;
    }
    .volu-results-mobile-row {
      display: flex;
      align-items: center;
      gap: 16px;
      background: #fff;
      border-radius: 16px;
      padding: 16px 20px;
      box-shadow: 0 2px 12px rgba(249,165,201,0.15);
    }
    .volu-results-mobile-pct {
      font-size: 32px;
      font-weight: 900;
      color: #f9a5c9;
      flex-shrink: 0;
      width: 70px;
    }
    .volu-results-mobile-text {
      font-size: 13px;
      color: #444;
      text-align: left;
      line-height: 1.4;
    }
  }
  /* Hide mobile rows on desktop */
  @media (min-width: 750px) {
    .volu-results-mobile {
      display: none;
    }
  }
  .volu-results-section h2 {
    font-size: clamp(22px, 3.5vw, 38px);
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 10px;
  }
  .volu-results-section .volu-results-sub {
    font-size: 16px;
    color: #777;
    margin-bottom: 50px;
  }
  .volu-results-cards {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto 40px;
  }
  .volu-results-card {
    background: #fff;
    border-radius: 24px;
    padding: 40px 30px 36px;
    flex: 1;
    min-width: 260px;
    max-width: 320px;
    box-shadow: 0 4px 24px rgba(249,165,201,0.10);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }
  .volu-big-ring {
    position: relative;
    width: 180px !important;
    height: 180px !important;
    flex-shrink: 0;
  }
  .volu-big-ring svg {
    transform: rotate(-90deg);
    width: 180px !important;
    height: 180px !important;
    display: block;
  }
  .volu-big-ring-bg {
    fill: none;
    stroke: #f9e4ef;
    stroke-width: 12;
  }
  .volu-big-ring-prog {
    fill: none;
    stroke: #f9a5c9;
    stroke-width: 12;
    stroke-linecap: round;
    stroke-dasharray: 470;
    stroke-dashoffset: 470;
    transition: stroke-dashoffset 2s ease;
  }
  .volu-big-ring-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px !important;
    font-weight: 800;
    color: #f9a5c9;
  }
  .volu-card-text {
    font-size: 15px;
    color: #444;
    line-height: 1.6;
    text-align: center;
  }
  .volu-shop-btn {
    display: inline-block;
    background: #1a1a1a;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    padding: 16px 60px;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .volu-shop-btn:hover { background: #c2185b; }
</style>

<div class="volu-results-section color-{{ section.settings.color_scheme }}">
  <h2>{{ section.settings.title | default: 'Real Women. Real Results.' }}</h2>
  <p class="volu-results-sub">{{ section.settings.text | default: 'Thousands of Volenu users tracked their pain levels before and after using the belt.' }}</p>

  <div class="volu-results-mobile">
    {%- for block in section.blocks -%}
      <div class="volu-results-mobile-row">
        <div class="volu-results-mobile-pct">{{ block.settings.percentage }}%</div>
        <div class="volu-results-mobile-text">{{ block.settings.row_text }}</div>
      </div>
    {%- endfor -%}
  </div>

  <div class="volu-results-cards">
    {%- for block in section.blocks -%}
      <div class="volu-results-card">
        <div class="volu-big-ring">
          <svg viewBox="0 0 180 180" width="180" height="180">
            <circle class="volu-big-ring-bg" cx="90" cy="90" r="75"/>
            <circle class="volu-big-ring-prog" cx="90" cy="90" r="75"
              data-pct="{{ block.settings.percentage }}"
              style="stroke-dasharray:470; stroke-dashoffset:470;"/>
          </svg>
          <div class="volu-big-ring-label">
            <span class="volu-big-count" data-target="{{ block.settings.percentage }}">0</span>%
          </div>
        </div>
        <div class="volu-card-text">{{ block.settings.row_text }}</div>
      </div>
    {%- endfor -%}
  </div>

  <a href="{{ section.settings.link | default: '/products' }}" class="volu-shop-btn">
    {{ section.settings.button_label | default: 'Shop Now' }}
  </a>
</div>

<script>
(function() {
  function animateBigRings() {
    var cards = document.querySelectorAll('.volu-results-card');
    cards.forEach(function(card, i) {
      setTimeout(function() {
        var circle = card.querySelector('.volu-big-ring-prog');
        var counter = card.querySelector('.volu-big-count');
        var pct = parseInt(circle.getAttribute('data-pct'));
        var circumference = 470;
        circle.style.strokeDashoffset = circumference - (circumference * pct / 100);
        var start = null;
        var duration = 2000;
        function step(ts) {
          if (!start) start = ts;
          var progress = Math.min((ts - start) / duration, 1);
          counter.textContent = Math.floor(progress * pct);
          if (progress < 1) requestAnimationFrame(step);
          else counter.textContent = pct;
        }
        requestAnimationFrame(step);
      }, i * 250);
    });
  }
  var section = document.querySelector('.volu-results-section');
  if (!section) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { animateBigRings(); observer.disconnect(); }
    });
  }, { threshold: 0.3 });
  observer.observe(section);
})();
</script>

<style>
  .volu-results-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 40px;
    padding: 60px 0;
  }
  .volu-results-left {
    flex: 1;
    min-width: 260px;
  }
  .volu-results-left h2 {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 16px;
  }
  .volu-results-left p {
    font-size: 15px;
    color: #555;
    line-height: 1.6;
  }
  .volu-results-right {
    flex: 1;
    min-width: 300px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .volu-result-row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid #f0f0f0;
  }
  .volu-result-row:last-child { border-bottom: none; padding-bottom: 0; }
  .volu-ring-wrap {
    position: relative;
    width: 72px;
    height: 72px;
    flex-shrink: 0;
  }
  .volu-ring-wrap svg {
    transform: rotate(-90deg);
    width: 72px;
    height: 72px;
  }
  .volu-ring-bg {
    fill: none;
    stroke: #f9e4ef;
    stroke-width: 5;
  }
  .volu-ring-progress {
    fill: none;
    stroke: #f9a5c9;
    stroke-width: 5;
    stroke-linecap: round;
    stroke-dasharray: 188;
    stroke-dashoffset: 188;
    transition: stroke-dashoffset 1.8s ease;
  }
  .volu-ring-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 800;
    color: #f9a5c9;
  }
  .volu-result-text {
    font-size: 14px;
    color: #333;
    line-height: 1.5;
  }
</style>

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="volu-results-wrap">
      <div class="volu-results-left">
        <h2>{{ section.settings.title | default: 'Real Women. Real Results.' }}</h2>
        <p>{{ section.settings.text | default: 'Thousands of Volenu users tracked their pain levels before and after using the belt. The numbers speak for themselves:' }}</p>
      </div>
      <div class="volu-results-right">
        {%- for block in section.blocks -%}
          {%- assign pct = block.settings.percentage -%}
          {%- assign circumference = 188 -%}
          {%- assign offset = circumference | minus: circumference | times: pct | divided_by: 100 -%}
          <div class="volu-result-row">
            <div class="volu-ring-wrap">
              <svg viewBox="0 0 72 72">
                <circle class="volu-ring-bg" cx="36" cy="36" r="30"/>
                <circle class="volu-ring-progress" cx="36" cy="36" r="30"
                  data-pct="{{ pct }}"
                  style="stroke-dasharray: {{ circumference }}; stroke-dashoffset: {{ circumference }};"/>
              </svg>
              <div class="volu-ring-label"><span class="volu-count" data-target="{{ pct }}">0</span>%</div>
            </div>
            <div class="volu-result-text">{{ block.settings.row_text }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  function animateRings() {
    var rows = document.querySelectorAll('.volu-result-row');
    rows.forEach(function(row, i) {
      setTimeout(function() {
        var circle = row.querySelector('.volu-ring-progress');
        var counter = row.querySelector('.volu-count');
        var pct = parseInt(circle.getAttribute('data-pct'));
        var circumference = 188;
        var offset = circumference - (circumference * pct / 100);
        circle.style.strokeDashoffset = offset;

        // Count up number
        var start = 0;
        var duration = 1800;
        var startTime = null;
        function step(timestamp) {
          if (!startTime) startTime = timestamp;
          var progress = Math.min((timestamp - startTime) / duration, 1);
          counter.textContent = Math.floor(progress * pct);
          if (progress < 1) requestAnimationFrame(step);
          else counter.textContent = pct;
        }
        requestAnimationFrame(step);
      }, i * 200);
    });
  }

  // Trigger on scroll into view
  var section = document.querySelector('.volu-results-wrap');
  if (!section) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        animateRings();
        observer.disconnect();
      }
    });
  }, { threshold: 0.3 });
  observer.observe(section);
})();
</script>

