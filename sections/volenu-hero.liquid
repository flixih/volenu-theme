<style>
  .volu-hero {
    background: #FFFFFF;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 80px 24px;
  }

  .volu-hero__inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .volu-hero__text {
    z-index: 2;
  }

  .volu-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #F5F5F5;
    border: 1px solid #E5E5E5;
    color: #666666;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
  }

  .volu-hero__badge-dot {
    width: 6px;
    height: 6px;
    background: #FF5A1F;
    border-radius: 50%;
  }

  .volu-hero__headline {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    color: #111111;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
  }

  .volu-hero__headline .accent {
    color: #FF5A1F;
  }

  .volu-hero__sub {
    font-size: 18px;
    color: #666666;
    line-height: 1.6;
    margin: 0 0 36px;
    max-width: 440px;
    font-weight: 400;
  }

  .volu-hero__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 40px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .volu-hero__bullets li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: #333333;
    font-weight: 500;
  }

  .volu-hero__bullets li::before {
    content: '';
    width: 18px;
    height: 18px;
    background: #FF5A1F;
    border-radius: 50%;
    flex-shrink: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4L3.5 6.5L9 1' stroke='white' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: center;
  }

  .volu-hero__cta-row {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .volu-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FF5A1F;
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 600;
    padding: 16px 32px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    letter-spacing: 0.01em;
  }

  .volu-hero__btn:hover {
    background: #e04a12;
    transform: translateY(-1px);
  }

  .volu-hero__trust {
    font-size: 13px;
    color: #999999;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .volu-hero__stars {
    color: #F5A623;
    font-size: 14px;
  }

  .volu-hero__image {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .volu-hero__img-wrap {
    width: 100%;
    max-width: 560px;
    aspect-ratio: 1;
    background: #F5F5F5;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .volu-hero__img-wrap img {
    width: 90%;
    height: 90%;
    object-fit: contain;
    animation: volu-float 4s ease-in-out infinite;
  }

  .volu-hero__spec-tag {
    position: absolute;
    background: #FFFFFF;
    border: 1px solid #E5E5E5;
    border-radius: 12px;
    padding: 10px 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    font-size: 13px;
    font-weight: 600;
    color: #111111;
    white-space: nowrap;
  }

  .volu-hero__spec-tag span {
    color: #FF5A1F;
    display: block;
    font-size: 11px;
    font-weight: 400;
    color: #999;
    margin-top: 1px;
  }

  .volu-hero__spec-1 { top: 15%; left: -5%; }
  .volu-hero__spec-2 { bottom: 20%; right: -5%; }
  .volu-hero__spec-3 { top: 55%; left: -8%; }

  @keyframes volu-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @media (max-width: 768px) {
    .volu-hero__inner {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }
    .volu-hero__image { order: -1; }
    .volu-hero__sub { max-width: 100%; margin-left: auto; margin-right: auto; }
    .volu-hero__cta-row { justify-content: center; }
    .volu-hero__spec-1, .volu-hero__spec-2, .volu-hero__spec-3 { display: none; }
    .volu-hero__bullets { align-items: flex-start; text-align: left; }
  }
</style>

<section class="volu-hero" id="volu-hero-{{ section.id }}">
  <div class="volu-hero__inner">
    <div class="volu-hero__text">
      <div class="volu-hero__badge">
        <span class="volu-hero__badge-dot"></span>
        New Drop — AI Wearable Tech
      </div>
      <h1 class="volu-hero__headline">
        See the World<br>Through <span class="accent">AI.</span>
      </h1>
      <p class="volu-hero__sub">
        Real-time translation, 4K video, and voice control — all built into glasses you'd actually wear every day.
      </p>
      <ul class="volu-hero__bullets">
        <li>Real-Time AI Translation in 40+ Languages</li>
        <li>4K Photo & Video with Stabilization</li>
        <li>Hands-Free Voice Control</li>
        <li>30-Day Money Back Guarantee</li>
      </ul>
      <div class="volu-hero__cta-row">
        <a href="/products/ai-smart-glasses-with-real-time-translation-ai-assistant-4k-photo-taking-video-stabilization-camera-voice-control" class="volu-hero__btn">
          Shop Now — Free Shipping →
        </a>
        <div class="volu-hero__trust">
          <span class="volu-hero__stars">★★★★★</span>
          4.8 · 10,000+ customers
        </div>
      </div>
    </div>

    <div class="volu-hero__image">
      <div class="volu-hero__img-wrap">
        {%- assign hero_img = section.settings.hero_image -%}
        {%- if hero_img != blank -%}
          <img src="{{ hero_img | image_url: width: 800 }}" alt="Volenu AI Smart Glasses" loading="eager">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="volu-hero__spec-tag volu-hero__spec-1">
        4K UHD
        <span>Video Quality</span>
      </div>
      <div class="volu-hero__spec-tag volu-hero__spec-2">
        40+ Languages
        <span>AI Translation</span>
      </div>
      <div class="volu-hero__spec-tag volu-hero__spec-3">
        35g
        <span>Ultra Lightweight</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Volenu Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Product Image"
    }
  ],
  "presets": [{ "name": "Volenu Hero" }]
}
{% endschema %}
