<style>
  .volu-scroll-section {
    position: relative;
    height: 300vh;
    background: #0a0a0a;
  }
  .volu-sticky-wrap {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
  }
  .volu-canvas-wrap {
    position: absolute;
    inset: 0;
  }
  #volu-hero-img-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .volu-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 48px 60px;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 55%);
  }
  .volu-headline {
    font-size: clamp(36px, 6vw, 80px);
    font-weight: 800;
    color: #fff;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
  }
  .volu-headline .accent { color: #22c55e; }
  .volu-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .volu-bullets li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
  }
  .volu-bullets li::before {
    content: '✓';
    color: #22c55e;
    font-weight: 700;
    font-size: 14px;
  }
  .volu-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #22c55e;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    padding: 16px 32px;
    border-radius: 100px;
    text-decoration: none;
    width: fit-content;
    transition: background 0.2s;
  }
  .volu-cta:hover { background: #16a34a; }
  .volu-progress-bar {
    position: absolute;
    bottom: 0; left: 0;
    height: 3px;
    background: #22c55e;
    width: 0%;
    transition: width 0.1s;
  }
  .volu-scroll-hint {
    position: absolute;
    bottom: 80px;
    right: 48px;
    color: rgba(255,255,255,0.4);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .volu-scroll-arrow { animation: bounce 1.5s ease-in-out infinite; }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  @media (max-width: 768px) {
    .volu-overlay { padding: 0 20px 40px; }
    .volu-scroll-hint { display: none; }
  }
</style>

<div class="volu-scroll-section" id="volu-scroll-{{ section.id }}">
  <div class="volu-sticky-wrap">
    <div class="volu-canvas-wrap">
      <img id="volu-hero-img-{{ section.id }}"
        src="{{ 'frame_000_delay-0.04s.webp' | asset_url }}"
        alt="Volenu AI Smart Glasses"/>
    </div>
    <div class="volu-overlay">
      <h1 class="volu-headline">
        See the World<br>Through <span class="accent">AI.</span>
      </h1>
      <ul class="volu-bullets">
        <li>Real-Time AI Translation in 40+ Languages</li>
        <li>4K Photo & Video with Stabilization</li>
        <li>Hands-Free Voice Control</li>
        <li>30-Day Money Back Guarantee</li>
      </ul>
      <a href="/products/ai-smart-glasses-with-real-time-translation-ai-assistant-4k-photo-taking-video-stabilization-camera-voice-control" class="volu-cta">
        Shop Now — Free Shipping →
      </a>
    </div>
    <div class="volu-progress-bar" id="volu-progress-{{ section.id }}"></div>
    <div class="volu-scroll-hint">
      <span>Scroll</span>
      <span class="volu-scroll-arrow">↓</span>
    </div>
  </div>
</div>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.getElementById('volu-scroll-' + sectionId);
  var img = document.getElementById('volu-hero-img-' + sectionId);
  var progress = document.getElementById('volu-progress-' + sectionId);
  if (!section || !img) return;

  var TOTAL_FRAMES = 192;
  var frameUrls = [
    {% for i in (0..191) %}
      {% assign padded = i | prepend: '000' | slice: -3, 3 %}
      {% if i == 2 or i == 8 or i == 14 or i == 20 or i == 26 or i == 32 or i == 38 or i == 44 or i == 50 or i == 56 or i == 62 or i == 68 or i == 74 or i == 80 or i == 86 or i == 92 or i == 98 or i == 104 or i == 110 or i == 116 or i == 122 or i == 128 or i == 134 or i == 140 or i == 146 or i == 152 or i == 158 or i == 164 or i == 170 or i == 176 or i == 182 or i == 188 %}
        {% assign fname = 'frame_' | append: padded | append: '_delay-0.05s.webp' %}
      {% else %}
        {% assign fname = 'frame_' | append: padded | append: '_delay-0.04s.webp' %}
      {% endif %}
      '{{ fname | asset_url }}'{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  var frames = new Array(TOTAL_FRAMES);
  for (var i = 0; i < TOTAL_FRAMES; i++) {
    (function(idx) {
      var preImg = new Image();
      preImg.src = frameUrls[idx];
      frames[idx] = preImg;
    })(i);
  }

  var currentFrameFloat = 0;
  var targetFrameFloat = 0;
  var lastDrawnIdx = -1;
  var velocity = 0;
  var lastTarget = 0;

  function getTargetFrame() {
    var rect = section.getBoundingClientRect();
    var scrolled = -rect.top;
    var maxScroll = section.offsetHeight - window.innerHeight;
    if (scrolled < 0) scrolled = 0;
    if (scrolled > maxScroll) scrolled = maxScroll;
    return maxScroll > 0 ? (scrolled / maxScroll) * (TOTAL_FRAMES - 1) : 0;
  }

  function loop() {
    velocity *= 0.85;
    targetFrameFloat += velocity;
    targetFrameFloat = Math.max(0, Math.min(TOTAL_FRAMES - 1, targetFrameFloat));
    currentFrameFloat += (targetFrameFloat - currentFrameFloat) * 0.12;
    var idx = Math.round(currentFrameFloat);
    idx = Math.max(0, Math.min(TOTAL_FRAMES - 1, idx));
    if (idx !== lastDrawnIdx) {
      lastDrawnIdx = idx;
      if (frames[idx] && frames[idx].complete && frames[idx].naturalWidth > 0) {
        img.src = frames[idx].src;
      }
    }
    if (progress) progress.style.width = ((currentFrameFloat / (TOTAL_FRAMES - 1)) * 100) + '%';
    requestAnimationFrame(loop);
  }

  window.addEventListener('scroll', function() {
    var newTarget = getTargetFrame();
    velocity = newTarget - lastTarget;
    lastTarget = newTarget;
    targetFrameFloat = newTarget;
  }, { passive: true });

  loop();
})();
</script>

{% schema %}
{
  "name": "Volenu Hero",
  "presets": [{ "name": "Volenu Hero" }]
}
{% endschema %}
