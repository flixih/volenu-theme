{% comment %} Volenu Product Animation — simple autoplay GIF {% endcomment %}

<style>
  .volu-prod-gif-wrap {
    width: 100%;
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 0;
  }
  .volu-prod-gif-wrap img {
    width: 100%;
    max-width: 500px;
    height: auto;
    display: block;
  }
  @media (min-width: 750px) {
    .volu-prod-gif-wrap {
      display: none;
    }
  }
</style>

<div class="volu-prod-gif-wrap">
  <img src="{{ 'volenu-product.gif' | asset_url }}" alt="Volenu Relief Belt" loading="lazy" />
</div>

{% schema %}
{
  "name": "Volenu Product Animation",
  "settings": []
}
{% endschema %}
