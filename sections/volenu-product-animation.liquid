{% comment %} Volenu Product Page — Autoplay Animation {% endcomment %}

<style>
  .volu-prod-video-wrap {
    width: 100%;
    background: #0a0a0a;
    display: block;
  }
  @media (min-width: 750px) {
    .volu-prod-video-wrap {
      display: none;
    }
  }
  .volu-prod-video-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>

<div class="volu-prod-video-wrap">
  <img 
    src="{{ 'volenu-animation.webp' | asset_url }}"
    alt="Volenu Relief Belt Animation"
    loading="lazy"
  />
</div>

{% schema %}
{
  "name": "Volenu Product Animation",
  "settings": []
}
{% endschema %}
