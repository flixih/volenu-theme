{% comment %} Volenu Product Animation — autoplay GIF, mobile only {% endcomment %}

<style>
  .volu-gif-section {
    width: 100%;
    background: #0a0a0a;
  }
  .volu-gif-section img {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (min-width: 750px) {
    .volu-gif-section {
      display: none;
    }
  }
</style>

<div class="volu-gif-section">
  <img src="{{ 'volenu-product.webp' | asset_url }}"
       alt="Volenu Relief Belt Animation"
       loading="eager"
  />
</div>

{% schema %}
{
  "name": "Volenu Product Animation",
  "settings": []
}
{% endschema %}
<!-- v2 -->
