<style>
  .volu-results-section {
    background: #000;
    padding: 100px 48px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .volu-results-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
  .volu-results-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.15em;
    text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 14px;
  }
  .volu-results-heading {
    font-size: clamp(28px, 4vw, 44px); font-weight: 800; color: #fff;
    margin: 0 0 16px; letter-spacing: -0.03em;
  }
  .volu-results-sub {
    font-size: 15px; color: rgba(255,255,255,0.4); margin: 0 0 64px;
  }
  .volu-results-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 2px;
    background: rgba(255,255,255,0.06); border-radius: 16px; overflow: hidden;
  }
  .volu-results-card {
    background: #0a0a0a; padding: 48px 32px; text-align: center;
    transition: background 0.2s;
  }
  .volu-results-card:hover { background: #111; }
  .volu-results-ring {
    position: relative; width: 140px; height: 140px; margin: 0 auto 28px;
  }
  .volu-results-ring svg { transform: rotate(-90deg); width: 140px; height: 140px; }
  .volu-results-ring circle { fill: none; stroke-width: 3; stroke-linecap: round; }
  .volu-results-ring .track { stroke: rgba(255,255,255,0.08); }
  .volu-results-ring .fill { stroke: #fff; }
  .volu-results-number {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    font-size: 32px; font-weight: 800; color: #fff; letter-spacing: -0.03em;
  }
  .volu-results-text { font-size: 14px; color: rgba(255,255,255,0.4); line-height: 1.6; }
  .volu-results-btn-wrap { margin-top: 56px; }
  .volu-results-btn {
    display: inline-flex; align-items: center; gap: 10px;
    background: #fff; color: #000; font-size: 14px; font-weight: 700;
    padding: 16px 36px; border-radius: 4px; text-decoration: none;
    letter-spacing: 0.05em; text-transform: uppercase;
    transition: opacity 0.2s;
  }
  .volu-results-btn:hover { opacity: 0.85; }
  @media (max-width: 768px) {
    .volu-results-section { padding: 60px 20px; }
    .volu-results-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="volu-results-section">
  <div class="volu-results-inner">
    <div class="volu-results-label">Verified Reviews</div>
    <h2 class="volu-results-heading">Real Collectors. Real Results.</h2>
    <p class="volu-results-sub">Thousands of Volenu customers rated their experience after purchasing.</p>
    <div class="volu-results-grid">
      <div class="volu-results-card">
        <div class="volu-results-ring">
          <svg viewBox="0 0 140 140">
            <circle class="track" cx="70" cy="70" r="60"/>
            <circle class="fill" cx="70" cy="70" r="60" stroke-dasharray="376.9" stroke-dashoffset="22.6"/>
          </svg>
          <div class="volu-results-number">94%</div>
        </div>
        <p class="volu-results-text">said their watches arrived in perfect condition every time</p>
      </div>
      <div class="volu-results-card">
        <div class="volu-results-ring">
          <svg viewBox="0 0 140 140">
            <circle class="track" cx="70" cy="70" r="60"/>
            <circle class="fill" cx="70" cy="70" r="60" stroke-dasharray="376.9" stroke-dashoffset="15.1"/>
          </svg>
          <div class="volu-results-number">96%</div>
        </div>
        <p class="volu-results-text">said the build quality exceeded their expectations</p>
      </div>
      <div class="volu-results-card">
        <div class="volu-results-ring">
          <svg viewBox="0 0 140 140">
            <circle class="track" cx="70" cy="70" r="60"/>
            <circle class="fill" cx="70" cy="70" r="60" stroke-dasharray="376.9" stroke-dashoffset="18.8"/>
          </svg>
          <div class="volu-results-number">95%</div>
        </div>
        <p class="volu-results-text">would recommend Volenu cases to fellow collectors</p>
      </div>
    </div>
    <div class="volu-results-btn-wrap">
      <a href="/collections/all" class="volu-results-btn">Shop The Collection →</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Results Big",
  "presets": [{ "name": "Results Big" }]
}
{% endschema %}
