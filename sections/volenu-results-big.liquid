<style>
  .volu-results {
    background: #F5F5F5;
    padding: 80px 24px;
  }
  .volu-results__inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .volu-results__label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #FF5A1F;
    margin-bottom: 12px;
  }
  .volu-results__heading {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    color: #111111;
    margin: 0 0 60px;
    letter-spacing: -0.02em;
  }
  .volu-results__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .volu-results__card {
    background: #FFFFFF;
    border: 1px solid #E5E5E5;
    border-radius: 16px;
    padding: 40px 24px;
    text-align: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }
  .volu-results__ring {
    position: relative;
    width: 120px;
    height: 120px;
    margin: 0 auto 24px;
  }
  .volu-results__ring svg {
    transform: rotate(-90deg);
    width: 120px;
    height: 120px;
  }
  .volu-results__ring circle {
    fill: none;
    stroke-width: 8;
    stroke-linecap: round;
  }
  .volu-results__ring .track { stroke: #E5E5E5; }
  .volu-results__ring .fill { stroke: #FF5A1F; transition: stroke-dashoffset 1.5s ease; }
  .volu-results__number {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 26px;
    font-weight: 800;
    color: #111111;
    letter-spacing: -0.02em;
  }
  .volu-results__text {
    font-size: 14px;
    color: #666666;
    line-height: 1.5;
    font-weight: 400;
  }
  .volu-results__btn-wrap {
    margin-top: 48px;
  }
  .volu-results__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #111111;
    color: #FFFFFF;
    font-size: 15px;
    font-weight: 600;
    padding: 14px 32px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .volu-results__btn:hover { background: #333333; }
  @media (max-width: 768px) {
    .volu-results__grid { grid-template-columns: 1fr; }
  }
</style>

<section class="volu-results">
  <div class="volu-results__inner">
    <div class="volu-results__label">Real Results</div>
    <h2 class="volu-results__heading">What Our Customers Say</h2>
    <div class="volu-results__grid">
      <div class="volu-results__card">
        <div class="volu-results__ring">
          <svg viewBox="0 0 120 120">
            <circle class="track" cx="60" cy="60" r="52"/>
            <circle class="fill" cx="60" cy="60" r="52" stroke-dasharray="326.7" stroke-dashoffset="19.6" data-target="94"/>
          </svg>
          <div class="volu-results__number">94%</div>
        </div>
        <p class="volu-results__text">said AI translation worked instantly in real-world use</p>
      </div>
      <div class="volu-results__card">
        <div class="volu-results__ring">
          <svg viewBox="0 0 120 120">
            <circle class="track" cx="60" cy="60" r="52"/>
            <circle class="fill" cx="60" cy="60" r="52" stroke-dasharray="326.7" stroke-dashoffset="13.1" data-target="96"/>
          </svg>
          <div class="volu-results__number">96%</div>
        </div>
        <p class="volu-results__text">said the 4K camera quality exceeded their expectations</p>
      </div>
      <div class="volu-results__card">
        <div class="volu-results__ring">
          <svg viewBox="0 0 120 120">
            <circle class="track" cx="60" cy="60" r="52"/>
            <circle class="fill" cx="60" cy="60" r="52" stroke-dasharray="326.7" stroke-dashoffset="16.3" data-target="95"/>
          </svg>
          <div class="volu-results__number">95%</div>
        </div>
        <p class="volu-results__text">would recommend Volenu AI Glasses to friends and family</p>
      </div>
    </div>
    <div class="volu-results__btn-wrap">
      <a href="/products/ai-smart-glasses-with-real-time-translation-ai-assistant-4k-photo-taking-video-stabilization-camera-voice-control" class="volu-results__btn">Get Yours Now →</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Results Big",
  "presets": [{ "name": "Results Big" }]
}
{% endschema %}
