{% comment %} Volenu — Odd Ritual style homepage {% endcomment %}

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ─── Hide Shopify default header ─── */
.shopify-section-header, .site-header, .header-section,
[id*="shopify-section-header"], [id*="announcement"],
.volenu-ticker-wrap, .sign-up-popup-overlay {
  display: none !important;
}

body { overflow-x: hidden; }

#vr-root {
  font-family: 'Outfit', sans-serif;
  color: #111;
  background: #fff;
}

/* ─── LOADER ─── */
/* ─── INTRO ANIMATION (Odd Ritual — single black screen slides up) ─── */
#vr-loader {
  position: fixed; inset: 0; z-index: 9999;
  background: #fff;
  display: flex; align-items: center; justify-content: center;
  transform: translateY(0);
  transition: transform 0.8s cubic-bezier(.87,0,.13,1);
}
#vr-loader.out { transform: translateY(-100%); }
#vr-loader.done { display: none; }
#vr-loader-logo {
  display: flex; align-items: center; justify-content: center;
}
#vr-loader-logo img {
  height: 36px; width: auto;
  filter: brightness(0) invert(1);
  opacity: 0;
  transform: translateY(10px);
  animation: vrLogoIn 0.7s ease 0.2s forwards;
}
@keyframes vrLogoIn {
  to { opacity: 1; transform: translateY(0); }
}

/* ── Draggable header strip ── */
/* ─── ANNOUNCEMENT BAR ─── */
#vr-header-strip {
  background: #111; color: #fff;
  height: 36px; overflow: hidden;
  position: relative; z-index: 600;
  display: flex; align-items: center;
}
.vr-hs-btn {
  background: none; border: none; color: #fff;
  font-size: 14px; cursor: pointer; padding: 0 10px;
  height: 100%; display: flex; align-items: center;
  opacity: 0.6; transition: opacity 0.2s; flex-shrink: 0;
  z-index: 2;
}
.vr-hs-btn:hover { opacity: 1; }
.vr-hs-messages {
  flex: 1; height: 100%;
  display: flex; align-items: center; justify-content: center;
  gap: 0;
}
.vr-hs-msg {
  display: none;
  align-items: center;
  font-size: 10px; letter-spacing: 0.2em; font-weight: 500;
  white-space: nowrap;
  transition: opacity 0.5s ease;
  pointer-events: none;
}
.vr-hs-msg.active { display: flex; pointer-events: auto; }

/* ─── NAV ─── */
/* ═══════════════════════════════
   PARIJAN-STYLE NAV
═══════════════════════════════ */
#vr-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 500;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px; height: 60px;
  transition: background 0.35s ease, box-shadow 0.35s ease;
}
#vr-nav.scrolled {
  background: #fff;
  box-shadow: 0 1px 0 rgba(0,0,0,0.08);
}

/* Left nav links */
.vr-nav-links {
  display: flex; align-items: center; gap: 4px;
  position: relative;
}
.vr-nav-item {
  position: relative;
}
.vr-nav-item > a,
.vr-nav-item > button {
  font-size: 11px; letter-spacing: 0.14em; font-weight: 500;
  text-decoration: none; color: #fff;
  background: none; border: none; cursor: pointer;
  padding: 8px 12px;
  display: flex; align-items: center; gap: 5px;
  transition: color 0.3s, opacity 0.2s;
  white-space: nowrap;
}
.vr-nav-item > a:hover,
.vr-nav-item > button:hover { opacity: 0.6; }
#vr-nav.scrolled .vr-nav-item > a,
#vr-nav.scrolled .vr-nav-item > button { color: #111; }
.vr-nav-sale > a { color: #c0392b !important; }
#vr-nav.scrolled .vr-nav-sale > a { color: #c0392b !important; }

/* Dropdown chevron */
.vr-nav-chevron {
  width: 8px; height: 8px;
  border-right: 1px solid currentColor;
  border-bottom: 1px solid currentColor;
  transform: rotate(45deg) translateY(-2px);
  display: inline-block;
  transition: transform 0.2s;
}
.vr-nav-item.open .vr-nav-chevron {
  transform: rotate(-135deg) translateY(-2px);
}

/* Dropdown panel */
.vr-nav-dropdown {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  background: #fff;
  border: 1px solid #e8e8e8;
  min-width: 200px;
  padding: 8px 0;
  z-index: 600;
  box-shadow: 0 8px 24px rgba(0,0,0,0.08);
}
.vr-nav-item.open .vr-nav-dropdown { display: block; }
.vr-nav-dropdown a {
  display: block;
  padding: 10px 20px;
  font-size: 11px; letter-spacing: 0.14em;
  color: #111; text-decoration: none;
  transition: background 0.15s;
}
.vr-nav-dropdown a:hover { background: #f5f5f5; }

/* Logo center */
.vr-nav-logo {
  text-decoration: none;
  position: absolute; left: 50%; transform: translateX(-50%);
  pointer-events: auto;
}
.vr-nav-logo img {
  height: 22px; width: auto; display: block;
  filter: brightness(0) invert(1);
  transition: filter 0.3s ease;
}
#vr-nav.scrolled .vr-nav-logo img { filter: brightness(0) invert(0); }

/* Right icons */
.vr-nav-right {
  display: flex; align-items: center; gap: 18px;
}
.vr-nav-right a,
.vr-nav-right button {
  color: #fff; background: none; border: none;
  cursor: pointer; padding: 0;
  display: flex; align-items: center;
  transition: color 0.3s, opacity 0.2s;
  text-decoration: none;
}
.vr-nav-right a:hover,
.vr-nav-right button:hover { opacity: 0.6; }
#vr-nav.scrolled .vr-nav-right a,
#vr-nav.scrolled .vr-nav-right button { color: #111; }
.vr-nav-right svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.4; }
.vr-nav-cart-count {
  font-size: 10px; letter-spacing: 0.1em;
  margin-left: 3px;
}

@media (max-width: 900px) {
  .vr-nav-links { display: none; }
  /* search stays visible on mobile - right side */
  .vr-ham-mobile { display: flex !important; }
  /* Hide account icon on mobile */
  .vr-nav-right a[href="/account"] { display: none; }
}
@media (min-width: 901px) {
  .vr-ham-mobile { display: none !important; }
}
/* Mobile hamburger — LEFT side */
.vr-ham-mobile {
  background: none; border: none; cursor: pointer;
  display: none;
  align-items: center; justify-content: center;
  padding: 4px;
  color: #fff;
  z-index: 10;
}
#vr-nav.scrolled .vr-ham-mobile { color: #111; }
.vr-ham-mobile svg { stroke: currentColor; }
/* Old desktop menu btn — hide always (replaced by mobile one) */
#vr-menu-btn { display: none !important; }

/* ─── MOBILE MENU ─── */
#vr-menu {
  position: fixed; inset: 0; z-index: 800;
  background: #fff;
  display: flex; flex-direction: column;
  padding: 0;
  transform: translateX(-100%);
  transition: transform 0.4s cubic-bezier(.87,0,.13,1);
  overflow-y: auto;
}
#vr-menu.open { transform: translateX(0); }
#vr-menu-close {
  position: absolute; top: 16px; right: 20px;
  background: none; border: none; color: #111;
  font-size: 22px; cursor: pointer; line-height: 1;
  width: 32px; height: 32px;
  display: flex; align-items: center; justify-content: center;
  border: 1.5px solid #111; border-radius: 50%;
}
/* Menu nav links */
.vr-menu-links {
  flex: 1;
  padding: 60px 0 20px 0;
  border-bottom: 1px solid #e8e8e8;
}
.vr-menu-links a {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 28px;
  font-size: 18px; font-weight: 500; letter-spacing: 0.02em;
  color: #111; text-decoration: none;
  border-bottom: 1px solid #f0f0f0;
  transition: background 0.15s;
}
.vr-menu-links a:last-child { border-bottom: none; }
.vr-menu-links a:hover { background: #f9f9f9; }
.vr-menu-links a.sale { color: #c0392b; }
.vr-menu-link-arrow {
  width: 7px; height: 7px;
  border-right: 1.5px solid #111;
  border-top: 1.5px solid #111;
  transform: rotate(45deg);
  flex-shrink: 0;
}
.vr-menu-links a.sale .vr-menu-link-arrow { border-color: #c0392b; }
/* Menu footer */
.vr-menu-foot {
  padding: 24px 28px;
  display: flex; flex-direction: column; gap: 20px;
}
.vr-menu-socials {
  display: flex; gap: 18px;
}
.vr-menu-socials a {
  color: #111; text-decoration: none;
}
.vr-menu-socials svg {
  width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 1.5;
}
.vr-menu-bottom-row {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 16px; border-top: 1px solid #e8e8e8;
}
.vr-menu-account {
  font-size: 13px; letter-spacing: 0.1em; color: #111;
  text-decoration: none; font-weight: 500;
}
.vr-menu-currency-slot { display: flex; align-items: center; }
/* Contain BUCKS dropdown inside menu slot - open upward */
#vr-menu-currency-slot {
  position: relative;
}
#vr-menu-currency-slot * {
  box-shadow: none !important;
}
/* Force BUCKS dropdown to open upward and align left in menu footer */
#vr-menu-currency-slot [class*="dropdown"],
#vr-menu-currency-slot [class*="list"],
#vr-menu-currency-slot [class*="options"],
#vr-menu-currency-slot ul,
#vr-menu-currency-slot .bucks-dropdown {
  bottom: 100% !important;
  top: auto !important;
  left: 0 !important;
  right: auto !important;
  transform: none !important;
  min-width: 180px !important;
}
/* Keep desktop nav currency contained */
#vr-currency-wrap {
  position: relative;
}

/* ─── HERO PANELS ─── */
#vr-hero {
  position: relative; height: 100vh; overflow: hidden;
}
.vr-panel {
  position: absolute; inset: 0;
  opacity: 0; transition: opacity 1s ease;
  pointer-events: none;
}
.vr-panel.active { opacity: 1; pointer-events: auto; }
.vr-panel-img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
}
.vr-panel-bg {
  width: 100%; height: 100%;
  background-size: cover; background-position: center;
}

/* ── Smooth scroll lerp ── */
html {
  scroll-behavior: auto;
}
#vr-lenis-wrap {
  position: fixed; inset: 0; overflow: hidden;
}
#vr-scroll-content {
  will-change: transform;
}
.vr-panel-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.45) 100%);
}
.vr-panel-content {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  justify-content: flex-end;
  padding: 0 40px 56px;
}
.vr-panel-num {
  font-size: 10px; letter-spacing: 0.22em; color: rgba(255,255,255,0.6);
  margin-bottom: 8px;
}
.vr-panel-title {
  font-size: clamp(28px, 5vw, 52px);
  color: #fff; font-weight: 600;
  letter-spacing: -0.01em; line-height: 1.1;
  margin-bottom: 20px;
  max-width: 560px;
}
.vr-panel-cta {
  display: inline-flex; align-items: center; gap: 10px;
  color: #fff; text-decoration: none;
  font-size: 11px; letter-spacing: 0.18em; font-weight: 500;
  border-bottom: 1px solid rgba(255,255,255,0.5);
  padding-bottom: 4px;
  width: fit-content;
}
.vr-panel-cta:hover { border-color: #fff; }

/* Hero overlay text (40% off) */
.vr-hero-promo {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  color: #fff; pointer-events: none;
}
.vr-promo-small {
  font-size: clamp(9px, 1.1vw, 12px);
  letter-spacing: 0.28em; font-weight: 500; margin-bottom: 6px;
  color: #fff; text-shadow: 0 1px 8px rgba(0,0,0,0.4);
}
.vr-promo-big {
  font-size: clamp(52px, 10vw, 112px);
  font-weight: 800; letter-spacing: -0.02em; line-height: 0.9;
  color: #fff; text-shadow: 0 2px 16px rgba(0,0,0,0.25); margin-bottom: 10px;
}
.vr-promo-sub {
  font-size: clamp(14px, 2vw, 24px);
  font-style: italic; letter-spacing: 0.06em;
  color: #fff; text-shadow: 0 1px 8px rgba(0,0,0,0.4);
}

/* Hero nav dots */
#vr-dots {
  position: absolute; bottom: 32px; right: 40px;
  display: flex; flex-direction: column; gap: 8px; z-index: 10;
}
.vr-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(255,255,255,0.4); cursor: pointer;
  transition: background 0.3s, transform 0.3s;
  border: none;
}
.vr-dot.active { background: #fff; transform: scale(1.3); }

/* Scroll indicator */
#vr-scroll-hint {
  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  color: rgba(255,255,255,0.7); font-size: 9px; letter-spacing: 0.2em;
  animation: vrBounce 2s ease infinite;
}
@keyframes vrBounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(6px); }
}
#vr-scroll-hint svg { width: 20px; height: 20px; }

/* ─── MARQUEE ─── */
.vr-marquee {
  overflow: hidden; border-top: 1px solid #e8e8e8;
  border-bottom: 1px solid #e8e8e8; padding: 14px 0;
  background: #fff;
}
.vr-marquee-track {
  display: flex; white-space: nowrap;
  animation: vrMarquee 28s linear infinite;
}
.vr-marquee-track span {
  font-size: 10px; letter-spacing: 0.2em; color: #999;
  padding: 0 40px; flex-shrink: 0;
}
@keyframes vrMarquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ─── LOGO + MANIFESTO (Odd Ritual bird+text style) ─── */
#vr-manifesto {
  padding: 80px 40px;
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 64px;
  align-items: center;
  max-width: 1100px;
  margin: 0 auto;
  opacity: 1; transform: translateY(0);
  transition: opacity 0.9s ease, transform 0.9s ease;
}
#vr-manifesto.visible { opacity: 1; transform: translateY(0); }
.vr-manifesto-logo { width: 100%; max-width: 160px; display: block; }
.vr-manifesto-label {
  font-size: 9px; letter-spacing: 0.3em; color: #999;
  margin-bottom: 16px; display: block;
}
#vr-manifesto p {
  font-size: clamp(18px, 2.4vw, 26px);
  line-height: 1.5; color: #111; font-weight: 700;
  letter-spacing: -0.01em;
}
#vr-manifesto strong { color: #111; }

/* ─── SHOP NOW HOVER FALL (Odd Ritual exact) ─── */
.vr-sn-content {
  padding: 0 40px 40px;
}
.vr-sn-line {
  display: block;
  overflow: hidden;
  line-height: 1;
  margin-bottom: 2px;
}
.vr-sn-inner {
  display: block;
  font-size: clamp(22px, 3vw, 42px);
  font-weight: 600; color: #fff;
  letter-spacing: 0em; line-height: 1.1;
  transition: transform 0.55s cubic-bezier(.87,0,.13,1);
}
/* SHOP NOW — always visible, no animation */
.vr-sn-top .vr-sn-inner {
  transition: none;
}
/* EXPLORE THE COLLECTION — falls on proximity */
.vr-sn-sub .vr-sn-inner {
  color: rgba(255,255,255,0.45);
  transition: transform 0.55s cubic-bezier(.87,0,.13,1);
}
#vr-hero.sn-near .vr-sn-sub .vr-sn-inner { transform: translateY(115%); }

/* ─── FEATURED PRODUCTS ─── */
#vr-products { padding: 0 0 64px; }
.vr-products-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40px 24px;
}
.vr-products-label { font-size: 9px; letter-spacing: 0.3em; color: #999; }
.vr-products-all {
  font-size: 10px; letter-spacing: 0.16em; color: #111;
  text-decoration: none; border-bottom: 1px solid #111;
  padding-bottom: 2px;
}
.vr-products-scroll {
  display: flex; gap: 0;
  padding: 0;
  overflow: hidden;
  position: relative;
}
.vr-products-scroll::-webkit-scrollbar { display: none; }
.vr-products-track {
  display: flex; gap: 2px;
  animation: vrProdScroll 40s linear infinite;
  will-change: transform;
}
.vr-products-track:hover { animation-play-state: paused; }
@keyframes vrProdScroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.vr-prod-card {
  flex-shrink: 0; width: 280px;
  scroll-snap-align: start;
  cursor: pointer;
  opacity: 1; transform: translateY(0);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.vr-prod-card.visible { opacity: 1; transform: translateY(0); }
.vr-prod-card:nth-child(1) { transition-delay: 0s; }
.vr-prod-card:nth-child(2) { transition-delay: 0.08s; }
.vr-prod-card:nth-child(3) { transition-delay: 0.16s; }
.vr-prod-card:nth-child(4) { transition-delay: 0.24s; }
.vr-prod-card:nth-child(5) { transition-delay: 0.32s; }
.vr-prod-img {
  position: relative; background: #f4f4f4;
  aspect-ratio: 3/4; overflow: hidden; margin-bottom: 14px;
}
.vr-prod-img img {
  position: absolute; inset: 0;
  width: 100%; height: 100%; object-fit: cover;
  transition: opacity 0.5s ease;
}
.vr-prod-img .hover-img { opacity: 0; }
.vr-prod-card:hover .vr-prod-img .main-img { opacity: 0; }
.vr-prod-card:hover .vr-prod-img .hover-img { opacity: 1; }
.vr-prod-save {
  position: absolute; top: 10px; left: 10px;
  background: #cc0000; color: #fff;
  font-size: 9px; font-weight: 700; letter-spacing: 0.06em;
  padding: 3px 8px; z-index: 2;
}
.vr-prod-quick {
  position: absolute; bottom: 10px; left: 10px; right: 10px;
  background: rgba(17,17,17,0.9); color: #fff; border: none;
  font-size: 9px; letter-spacing: 0.16em; font-weight: 600;
  padding: 10px; cursor: pointer; opacity: 0;
  transform: translateY(6px);
  transition: opacity 0.2s, transform 0.2s;
  font-family: inherit;
}
.vr-prod-card:hover .vr-prod-quick { opacity: 1; transform: translateY(0); }
.vr-prod-name { font-size: 10px; letter-spacing: 0.1em; font-weight: 600; margin-bottom: 4px; }
.vr-prod-prices { display: flex; gap: 8px; align-items: center; }
.vr-prod-orig { font-size: 11px; color: #bbb; text-decoration: line-through; }
.vr-prod-sale { font-size: 11px; color: #cc0000; font-weight: 600; }
.vr-prod-price { font-size: 11px; color: #555; }

/* ─── THREE TILES ─── */
#vr-tiles {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
  padding: 0 2px 64px;
}
.vr-tile {
  position: relative; aspect-ratio: 3/4; overflow: hidden; cursor: pointer;
  opacity: 1; transform: translateY(0);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
.vr-tile--link {
  display: block; text-decoration: none;
  cursor: pointer;
}
.vr-tile--link:hover img { transform: scale(1.03); }
/* Draggable product scroll */
.vr-products-scroll { cursor: grab; }
.vr-products-scroll.is-dragging { cursor: grabbing; animation-play-state: paused; }
.vr-products-scroll.is-dragging .vr-products-track { animation-play-state: paused; }
.vr-tile:nth-child(2) { transition-delay: 0.12s; }
.vr-tile:nth-child(3) { transition-delay: 0.24s; }
.vr-tile img {
  width: 100%; height: 100%; object-fit: cover;
  transform: scale(1.04); transition: transform 0.7s ease;
}
.vr-tile:hover img { transform: scale(1); }
.vr-tile-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.6) 100%);
}
.vr-tile-content {
  position: absolute; bottom: 24px; left: 24px; right: 24px;
}
.vr-tile-eyebrow { font-size: 9px; letter-spacing: 0.24em; color: rgba(255,255,255,0.65); margin-bottom: 4px; }
.vr-tile-title { font-size: 16px; font-weight: 600; color: #fff; letter-spacing: 0.02em; margin-bottom: 10px; }
.vr-tile-cta {
  display: inline-block; font-size: 9px; letter-spacing: 0.18em;
  color: #fff; text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.5); padding-bottom: 2px;
}

/* ─── BRAND STATEMENT ─── */
#vr-statement {
  padding: 80px 40px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 64px;
  align-items: center;
  background: #fff;
}
.vr-statement-label { font-size: 9px; letter-spacing: 0.3em; color: #999; margin-bottom: 16px; }
.vr-statement-text { font-size: clamp(15px, 2vw, 20px); line-height: 1.7; color: #333; }
.vr-statement-num {
  font-size: clamp(80px, 14vw, 140px); font-weight: 700;
  color: #f0f0f0; line-height: 1; letter-spacing: -0.04em;
  text-align: right;
}

/* ─── GALLERY ─── */
#vr-gallery {
  padding: 0 0 64px;
  background: #fff;
}
.vr-gallery-head {
  display: flex; flex-direction: column; align-items: center;
  text-align: center; padding: 64px 40px 40px;
}
.vr-gallery-label {
  font-size: 22px; letter-spacing: -0.01em; font-weight: 700;
  color: #111; margin-bottom: 12px;
}
.vr-gallery-sub {
  font-size: 13px; color: #777; letter-spacing: 0.03em;
  max-width: 480px; line-height: 1.6;
}
.vr-gallery-hint { display: none; }
.vr-gallery-scroll {
  display: flex; gap: 2px;
  overflow-x: auto; scrollbar-width: none;
  scroll-snap-type: x mandatory;
  cursor: grab;
}
.vr-gallery-scroll::-webkit-scrollbar { display: none; }
.vr-gallery-scroll:active { cursor: grabbing; }
.vr-gallery-item {
  flex-shrink: 0; width: 240px; height: 320px;
  scroll-snap-align: start; overflow: hidden; background: #f0f0f0;
}
.vr-gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.vr-gallery-item:hover img { transform: scale(1.04); }

