  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 16px; letter-spacing: 0.22em; font-weight: 600;
  color: #fff; text-transform: uppercase;
  white-space: nowrap;
}

@media (max-width: 768px) {
  .vr-coll-row, .vr-cat-row { padding: 40px 20px 32px; }
  .vr-coll-grid { grid-template-columns: repeat(2, 1fr); }
  .vr-cat-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>


<!-- SHOP THE LOOK -->
<section class="vr-coll-row">
  <div class="vr-coll-head">
    <div class="vr-coll-title">Shop The Look</div>
    <a href="/collections/outfits" class="vr-coll-viewall">VIEW ALL →</a>
  </div>
  <div class="vr-coll-grid">
    {% assign look_col = collections['outfits'] %}
    {% if look_col and look_col.products.size > 0 %}
      {% assign look_products = look_col.products %}
    {% else %}
      {% assign look_products = collections.all.products %}
    {% endif %}
    {% for product in look_products limit: 4 %}
      {% assign savings = product.compare_at_price_max | minus: product.price %}
      <div class="vr-coll-card" onclick="window.location='{{ product.url }}'">
        <div class="vr-coll-img-wrap">
          {% if product.images.size > 0 %}
            <img class="vr-coll-img" src="{{ product.images[0] | img_url: '600x' }}" alt="{{ product.title }}" loading="lazy">
          {% endif %}
          {% if savings > 0 %}
            <div class="vr-coll-save">SAVE {{ savings | money }}</div>
          {% endif %}
        </div>
        <div class="vr-coll-info">
          <div class="vr-coll-name">{{ product.title }}</div>
          <div class="vr-coll-prices">
            {% if product.compare_at_price_max > product.price %}
              <span class="vr-coll-orig">{{ product.compare_at_price_max | money }}</span>
              <span class="vr-coll-sale">{{ product.price | money }}</span>
            {% else %}
              <span class="vr-coll-price">{{ product.price | money }}</span>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

