<style>
/* Hide the floating BUCKS currency widget */
[class*="bucks-currency"], [id*="bucks-currency"],
[class*="currency-selector"]:not(.vr-currency-wrap),
.boost-currency-switcher,
iframe[src*="currency"] { display: none !important; }

/* Style our nav currency wrap */
.vr-currency-wrap {
  display: flex;
  align-items: center;
}
.vr-currency-wrap select {
  background: none;
  border: none;
  color: #fff;
  font-size: 10px;
  letter-spacing: 0.12em;
  cursor: pointer;
  outline: none;
  padding: 0;
  font-family: inherit;
  -webkit-appearance: none;
}
#vr-nav.scrolled .vr-currency-wrap select { color: #111; }
@media (max-width: 900px) { .vr-currency-wrap { display: none; } }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Move BUCKS currency widget into nav
  var wrap = document.getElementById('vr-currency-wrap');
  if (!wrap) return;
  
  function moveCurrency() {
    // Try to find the BUCKS widget
    var widget = document.querySelector('[class*="bucks-currency"], [id*="currency-switcher"], .boost-currency-switcher, [data-currency-selector]');
    if (widget && !wrap.contains(widget)) {
      wrap.appendChild(widget);
      widget.style.display = 'block';
    }
  }
  
  // Try immediately and after a delay
  moveCurrency();
  setTimeout(moveCurrency, 1000);
  setTimeout(moveCurrency, 2500);
});
</script>

