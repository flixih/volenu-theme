<style>
/* Hide the floating BUCKS currency widget - aggressive */
[class*="bucks-currency"], [id*="bucks-currency"], .boost-currency-switcher, .currency-converter { display: none !important; }

/* Style our nav currency wrap */
.vr-currency-wrap {
  display: flex;
  align-items: center;
}
.vr-currency-wrap select {
  background: none;
  border: none;
  color: #fff;
  font-size: 10px;
  letter-spacing: 0.12em;
  cursor: pointer;
  outline: none;
  padding: 0;
  font-family: inherit;
  -webkit-appearance: none;
}
#vr-nav.scrolled .vr-currency-wrap select { color: #111; }
@media (max-width: 900px) { .vr-currency-wrap { display: none; } }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Move BUCKS currency widget into nav
  var wrap = document.getElementById('vr-currency-wrap');
  if (!wrap) return;
  
  function moveCurrency() {
    // Try multiple selectors to find the BUCKS widget
    var selectors = [
      '[class*="bucks-currency"]',
      '[id*="currency-switcher"]', 
      '[id*="bucks"]',
      '.boost-currency-switcher',
      '[data-currency-selector]',
      '[class*="currency-selector"]',
      '[class*="currency-switcher"]'
    ];
    for (var i = 0; i < selectors.length; i++) {
      var widget = document.querySelector(selectors[i]);
      if (widget && !wrap.contains(widget)) {
        widget.style.display = 'block';
        widget.style.position = 'static';
        widget.style.background = 'none';
        widget.style.border = 'none';
        widget.style.boxShadow = 'none';
        wrap.appendChild(widget);
        return true;
      }
    }
    return false;
  }
  
  moveCurrency();
  setTimeout(moveCurrency, 500);
  setTimeout(moveCurrency, 1500);
  setTimeout(moveCurrency, 3000);
});
</script>

