<style>
/* ── Shared collection row ── */
.vr-coll-row {
  padding: 56px 40px 48px;
  border-top: 1px solid #ececec;
  background: #fff;
}
.vr-coll-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 32px;
}
.vr-coll-title {
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 400; letter-spacing: 0.06em;
  text-transform: uppercase; color: #111;
  font-family: 'Bebas Neue', 'Oswald', sans-serif;
  line-height: 1;
}
.vr-coll-viewall {
  display: inline-flex; align-items: center; gap: 6px;
  background: #111; color: #fff;
  font-size: 10px; letter-spacing: 0.16em; font-weight: 600;
  text-decoration: none; padding: 10px 20px;
  text-transform: uppercase;
  transition: background 0.2s;
}
.vr-coll-viewall:hover { background: #333; }
.vr-coll-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
}
.vr-coll-card {
  cursor: pointer; background: #f5f5f5;
}
.vr-coll-card:hover .vr-coll-img { transform: scale(1.03); }
.vr-coll-img-wrap {
  aspect-ratio: 3/4; overflow: hidden; position: relative;
}
.vr-coll-img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.5s ease; display: block;
}
.vr-coll-save {
  position: absolute; top: 10px; left: 10px;
  background: #cc0000; color: #fff;
  font-size: 9px; font-weight: 700; letter-spacing: 0.06em;
  padding: 3px 8px; z-index: 2;
}
.vr-coll-info { padding: 12px 4px 4px; }
.vr-coll-name {
  font-size: 10px; letter-spacing: 0.1em; font-weight: 600;
  text-transform: uppercase; margin-bottom: 4px; color: #111;
}
.vr-coll-prices { display: flex; gap: 8px; align-items: center; }
.vr-coll-orig { font-size: 11px; color: #bbb; text-decoration: line-through; }
.vr-coll-sale { font-size: 11px; color: #cc0000; font-weight: 600; }
.vr-coll-price { font-size: 11px; color: #555; }

/* ── Shop by category ── */
.vr-cat-row {
  padding: 56px 40px 48px;
  border-top: 1px solid #ececec;
  background: #fff;
}
.vr-cat-title {
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 800; letter-spacing: -0.02em;
  text-transform: uppercase; color: #111; margin-bottom: 24px;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  line-height: 1;
}
.vr-cat-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
}
.vr-cat-item {
  position: relative; aspect-ratio: 3/4; overflow: hidden; cursor: pointer;
  text-decoration: none; display: block;
}
.vr-cat-item img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.5s ease, filter 0.3s ease;
  filter: brightness(0.6);
}
.vr-cat-item:hover img { transform: scale(1.04); filter: brightness(0.5); }
.vr-cat-item-overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.15);
  transition: background 0.3s;
}
.vr-cat-item:hover .vr-cat-item-overlay { background: rgba(0,0,0,0.25); }
.vr-cat-label {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 16px; letter-spacing: 0.22em; font-weight: 600;
  color: #fff; text-transform: uppercase;
  white-space: nowrap;
}

@media (max-width: 768px) {
  .vr-coll-row, .vr-cat-row { padding: 40px 20px 32px; }
  .vr-coll-grid { grid-template-columns: repeat(2, 1fr); }
  .vr-cat-grid { grid-template-columns: repeat(2, 1fr); }
}
