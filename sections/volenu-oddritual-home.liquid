{% comment %} Volenu — Odd Ritual style homepage {% endcomment %}

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ─── Hide Shopify default header ─── */
.shopify-section-header, .site-header, .header-section,
[id*="shopify-section-header"], [id*="announcement"],
.volenu-ticker-wrap, .sign-up-popup-overlay {
  display: none !important;
}

body { overflow-x: hidden; }

#vr-root {
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #111;
  background: #fff;
}

/* ─── LOADER ─── */
#vr-loader {
  position: fixed; inset: 0; z-index: 9999;
  background: #fff;
  display: flex; align-items: center; justify-content: center;
  transition: opacity 0.6s ease, visibility 0.6s ease;
}
#vr-loader.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
#vr-loader-logo {
  font-size: 13px; letter-spacing: 0.3em; font-weight: 500;
  color: #111; opacity: 0;
  animation: vrFadeIn 0.8s ease 0.3s forwards;
}
@keyframes vrFadeIn { to { opacity: 1; } }

/* ─── NAV ─── */
#vr-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 500;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px; height: 60px;
  transition: background 0.4s ease;
}
.vr-nav-logo {
  text-decoration: none;
}
.vr-nav-logo img {
  height: 22px; width: auto; display: block;
  filter: invert(1); /* white on hero */
  transition: filter 0.4s ease;
}
#vr-nav.scrolled .vr-nav-logo img {
  filter: invert(0); /* black when scrolled */
}
.vr-nav-right { display: flex; align-items: center; gap: 24px; }
.vr-nav-right a {
  font-size: 10px; letter-spacing: 0.18em; font-weight: 500;
  color: #fff; text-decoration: none;
  transition: color 0.4s ease;
}
#vr-nav.scrolled .vr-nav-right a { color: #111; }
.vr-cart-count {
  font-size: 10px; letter-spacing: 0.1em; color: #fff;
}
#vr-menu-btn {
  background: none; border: none; cursor: pointer;
  display: flex; flex-direction: column; gap: 5px; padding: 4px;
}
#vr-menu-btn span {
  display: block; width: 22px; height: 1px; background: #fff;
  transition: background 0.4s ease;
}
#vr-nav.scrolled #vr-menu-btn span { background: #111; }

/* ─── MOBILE MENU ─── */
#vr-menu {
  position: fixed; inset: 0; z-index: 800;
  background: #111;
  display: flex; flex-direction: column;
  justify-content: center; padding: 48px 40px;
  transform: translateY(-100%);
  transition: transform 0.6s cubic-bezier(.87,0,.13,1);
}
#vr-menu.open { transform: translateY(0); }
#vr-menu-close {
  position: absolute; top: 20px; right: 28px;
  background: none; border: none; color: #fff;
  font-size: 28px; cursor: pointer; line-height: 1;
}
.vr-menu-links a {
  display: block; font-size: clamp(32px, 6vw, 56px);
  color: #fff; text-decoration: none;
  font-weight: 600; letter-spacing: -0.01em;
  line-height: 1.1; margin-bottom: 12px;
  opacity: 0; transform: translateY(20px);
  transition: opacity 0.4s ease, transform 0.4s ease;
}
#vr-menu.open .vr-menu-links a { opacity: 1; transform: translateY(0); }
#vr-menu.open .vr-menu-links a:nth-child(1) { transition-delay: 0.15s; }
#vr-menu.open .vr-menu-links a:nth-child(2) { transition-delay: 0.2s; }
#vr-menu.open .vr-menu-links a:nth-child(3) { transition-delay: 0.25s; }
#vr-menu.open .vr-menu-links a:nth-child(4) { transition-delay: 0.3s; }
#vr-menu.open .vr-menu-links a:nth-child(5) { transition-delay: 0.35s; }
.vr-menu-foot {
  position: absolute; bottom: 40px; left: 40px;
  font-size: 10px; color: #666; letter-spacing: 0.12em;
}

/* ─── HERO PANELS ─── */
#vr-hero {
  position: relative; height: 100vh; overflow: hidden;
}
.vr-panel {
  position: absolute; inset: 0;
  opacity: 0; transition: opacity 1s ease;
  pointer-events: none;
}
.vr-panel.active { opacity: 1; pointer-events: auto; }
.vr-panel-img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
}
.vr-panel-bg {
  width: 100%; height: 100%;
  background-size: cover; background-position: center;
}

/* ── Smooth scroll lerp ── */
html {
  scroll-behavior: auto;
}
#vr-lenis-wrap {
  position: fixed; inset: 0; overflow: hidden;
}
#vr-scroll-content {
  will-change: transform;
}
.vr-panel-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.45) 100%);
}
.vr-panel-content {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  justify-content: flex-end;
  padding: 0 40px 56px;
}
.vr-panel-num {
  font-size: 10px; letter-spacing: 0.22em; color: rgba(255,255,255,0.6);
  margin-bottom: 8px;
}
.vr-panel-title {
  font-size: clamp(28px, 5vw, 52px);
  color: #fff; font-weight: 600;
  letter-spacing: -0.01em; line-height: 1.1;
  margin-bottom: 20px;
  max-width: 560px;
}
.vr-panel-cta {
  display: inline-flex; align-items: center; gap: 10px;
  color: #fff; text-decoration: none;
  font-size: 11px; letter-spacing: 0.18em; font-weight: 500;
  border-bottom: 1px solid rgba(255,255,255,0.5);
  padding-bottom: 4px;
  width: fit-content;
}
.vr-panel-cta:hover { border-color: #fff; }

/* Hero overlay text (60% off) */
.vr-hero-promo {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  color: #fff; pointer-events: none;
}
.vr-promo-small {
  font-size: clamp(9px, 1.1vw, 12px);
  letter-spacing: 0.28em; font-weight: 500; margin-bottom: 6px;
  text-shadow: 0 1px 8px rgba(0,0,0,0.4);
}
.vr-promo-big {
  font-size: clamp(52px, 10vw, 112px);
  font-weight: 800; letter-spacing: -0.02em; line-height: 0.9;
  text-shadow: 0 2px 16px rgba(0,0,0,0.25); margin-bottom: 10px;
}
.vr-promo-sub {
  font-size: clamp(14px, 2vw, 24px);
  font-style: italic; letter-spacing: 0.06em;
  text-shadow: 0 1px 8px rgba(0,0,0,0.4);
}

/* Hero nav dots */
#vr-dots {
  position: absolute; bottom: 32px; right: 40px;
  display: flex; flex-direction: column; gap: 8px; z-index: 10;
}
.vr-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(255,255,255,0.4); cursor: pointer;
  transition: background 0.3s, transform 0.3s;
  border: none;
}
.vr-dot.active { background: #fff; transform: scale(1.3); }

/* Scroll indicator */
#vr-scroll-hint {
  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  color: rgba(255,255,255,0.7); font-size: 9px; letter-spacing: 0.2em;
  animation: vrBounce 2s ease infinite;
}
@keyframes vrBounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(6px); }
}
#vr-scroll-hint svg { width: 20px; height: 20px; }

/* ─── MARQUEE ─── */
.vr-marquee {
  overflow: hidden; border-top: 1px solid #e8e8e8;
  border-bottom: 1px solid #e8e8e8; padding: 14px 0;
  background: #fff;
}
.vr-marquee-track {
  display: flex; white-space: nowrap;
  animation: vrMarquee 28s linear infinite;
}
.vr-marquee-track span {
  font-size: 10px; letter-spacing: 0.2em; color: #999;
  padding: 0 40px; flex-shrink: 0;
}
@keyframes vrMarquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ─── LOGO + MANIFESTO (Odd Ritual bird+text style) ─── */
#vr-manifesto {
  padding: 80px 40px;
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 64px;
  align-items: center;
  max-width: 1100px;
  margin: 0 auto;
  opacity: 0; transform: translateY(32px);
  transition: opacity 0.9s ease, transform 0.9s ease;
}
#vr-manifesto.visible { opacity: 1; transform: translateY(0); }
.vr-manifesto-logo { width: 100%; max-width: 160px; display: block; }
.vr-manifesto-label {
  font-size: 9px; letter-spacing: 0.3em; color: #999;
  margin-bottom: 16px; display: block;
}
#vr-manifesto p {
  font-size: clamp(18px, 2.4vw, 26px);
  line-height: 1.5; color: #111; font-weight: 700;
  letter-spacing: -0.01em;
}
#vr-manifesto strong { color: #111; }

/* ─── SHOP NOW HOVER FALL ─── */
#vr-shopnow {
  position: relative;
  background: #5c5650;
  overflow: hidden;
  cursor: pointer;
  height: 220px;
  display: flex; align-items: flex-end;
}
#vr-shopnow-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%; object-fit: cover;
  opacity: 0.55;
}
.vr-sn-content {
  position: relative; z-index: 2;
  padding: 0 40px 32px;
}
.vr-sn-line {
  display: block;
  font-size: clamp(28px, 4.5vw, 52px);
  font-weight: 800; color: #fff;
  letter-spacing: -0.02em; line-height: 1;
  overflow: hidden;
}
.vr-sn-inner {
  display: block;
  transition: transform 0.55s cubic-bezier(.87,0,.13,1);
  transform: translateY(0);
}
/* "SHOP NOW" stays, subtitle falls down on hover */
.vr-sn-sub .vr-sn-inner {
  color: rgba(255,255,255,0.55);
  transform: translateY(0);
  transition: transform 0.5s cubic-bezier(.87,0,.13,1) 0.05s,
              color 0.4s ease;
}
#vr-shopnow:hover .vr-sn-sub .vr-sn-inner {
  transform: translateY(110%);
}
/* Underline dashes like Odd Ritual */
.vr-sn-dashes {
  display: flex; gap: 3px; margin-bottom: 10px;
  opacity: 0; transition: opacity 0.3s ease;
}
#vr-shopnow:hover .vr-sn-dashes { opacity: 1; }
.vr-sn-dashes span {
  width: 14px; height: 1px; background: rgba(255,255,255,0.5);
  display: block;
}

/* ─── FEATURED PRODUCTS ─── */
#vr-products { padding: 0 0 64px; }
.vr-products-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40px 24px;
}
.vr-products-label { font-size: 9px; letter-spacing: 0.3em; color: #999; }
.vr-products-all {
  font-size: 10px; letter-spacing: 0.16em; color: #111;
  text-decoration: none; border-bottom: 1px solid #111;
  padding-bottom: 2px;
}
.vr-products-scroll {
  display: flex; gap: 2px;
  padding: 0 40px;
  overflow-x: auto; scrollbar-width: none;
  scroll-snap-type: x mandatory;
}
.vr-products-scroll::-webkit-scrollbar { display: none; }
.vr-prod-card {
  flex-shrink: 0; width: 280px;
  scroll-snap-align: start;
  cursor: pointer;
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.vr-prod-card.visible { opacity: 1; transform: translateY(0); }
.vr-prod-card:nth-child(1) { transition-delay: 0s; }
.vr-prod-card:nth-child(2) { transition-delay: 0.08s; }
.vr-prod-card:nth-child(3) { transition-delay: 0.16s; }
.vr-prod-card:nth-child(4) { transition-delay: 0.24s; }
.vr-prod-card:nth-child(5) { transition-delay: 0.32s; }
.vr-prod-img {
  position: relative; background: #f4f4f4;
  aspect-ratio: 3/4; overflow: hidden; margin-bottom: 14px;
}
.vr-prod-img img {
  position: absolute; inset: 0;
  width: 100%; height: 100%; object-fit: cover;
  transition: opacity 0.5s ease;
}
.vr-prod-img .hover-img { opacity: 0; }
.vr-prod-card:hover .vr-prod-img .main-img { opacity: 0; }
.vr-prod-card:hover .vr-prod-img .hover-img { opacity: 1; }
.vr-prod-save {
  position: absolute; top: 10px; left: 10px;
  background: #cc0000; color: #fff;
  font-size: 9px; font-weight: 700; letter-spacing: 0.06em;
  padding: 3px 8px; z-index: 2;
}
.vr-prod-quick {
  position: absolute; bottom: 10px; left: 10px; right: 10px;
  background: rgba(17,17,17,0.9); color: #fff; border: none;
  font-size: 9px; letter-spacing: 0.16em; font-weight: 600;
  padding: 10px; cursor: pointer; opacity: 0;
  transform: translateY(6px);
  transition: opacity 0.2s, transform 0.2s;
  font-family: inherit;
}
.vr-prod-card:hover .vr-prod-quick { opacity: 1; transform: translateY(0); }
.vr-prod-name { font-size: 10px; letter-spacing: 0.1em; font-weight: 600; margin-bottom: 4px; }
.vr-prod-prices { display: flex; gap: 8px; align-items: center; }
.vr-prod-orig { font-size: 11px; color: #bbb; text-decoration: line-through; }
.vr-prod-sale { font-size: 11px; color: #cc0000; font-weight: 600; }
.vr-prod-price { font-size: 11px; color: #555; }

/* ─── THREE TILES ─── */
#vr-tiles {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
  padding: 0 2px 64px;
}
.vr-tile {
  position: relative; aspect-ratio: 3/4; overflow: hidden; cursor: pointer;
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
.vr-tile.visible { opacity: 1; transform: translateY(0); }
.vr-tile:nth-child(2) { transition-delay: 0.12s; }
.vr-tile:nth-child(3) { transition-delay: 0.24s; }
.vr-tile img {
  width: 100%; height: 100%; object-fit: cover;
  transform: scale(1.04); transition: transform 0.7s ease;
}
.vr-tile:hover img { transform: scale(1); }
.vr-tile-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.6) 100%);
}
.vr-tile-content {
  position: absolute; bottom: 24px; left: 24px; right: 24px;
}
.vr-tile-eyebrow { font-size: 9px; letter-spacing: 0.24em; color: rgba(255,255,255,0.65); margin-bottom: 4px; }
.vr-tile-title { font-size: 16px; font-weight: 600; color: #fff; letter-spacing: 0.02em; margin-bottom: 10px; }
.vr-tile-cta {
  display: inline-block; font-size: 9px; letter-spacing: 0.18em;
  color: #fff; text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.5); padding-bottom: 2px;
}

/* ─── BRAND STATEMENT ─── */
#vr-statement {
  padding: 80px 40px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 64px;
  align-items: center;
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
#vr-statement.visible { opacity: 1; transform: translateY(0); }
.vr-statement-label { font-size: 9px; letter-spacing: 0.3em; color: #999; margin-bottom: 16px; }
.vr-statement-text { font-size: clamp(15px, 2vw, 20px); line-height: 1.7; color: #333; }
.vr-statement-num {
  font-size: clamp(80px, 14vw, 140px); font-weight: 700;
  color: #f0f0f0; line-height: 1; letter-spacing: -0.04em;
  text-align: right;
}

/* ─── GALLERY ─── */
#vr-gallery {
  padding: 0 40px 64px;
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
#vr-gallery.visible { opacity: 1; transform: translateY(0); }
.vr-gallery-head {
  display: flex; justify-content: space-between; align-items: flex-end;
  margin-bottom: 20px;
}
.vr-gallery-label { font-size: 9px; letter-spacing: 0.3em; color: #999; }
.vr-gallery-hint { font-size: 9px; letter-spacing: 0.16em; color: #bbb; }
.vr-gallery-scroll {
  display: flex; gap: 2px;
  overflow-x: auto; scrollbar-width: none;
  scroll-snap-type: x mandatory;
  cursor: grab;
}
.vr-gallery-scroll::-webkit-scrollbar { display: none; }
.vr-gallery-scroll:active { cursor: grabbing; }
.vr-gallery-item {
  flex-shrink: 0; width: 240px; height: 320px;
  scroll-snap-align: start; overflow: hidden; background: #f0f0f0;
}
.vr-gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.vr-gallery-item:hover img { transform: scale(1.04); }

/* ─── FOOTER ─── */
#vr-footer {
  background: #111; color: #fff;
  padding: 64px 40px 32px;
}
.vr-footer-top {
  display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: 40px; margin-bottom: 56px;
}
.vr-footer-brand { font-size: 13px; letter-spacing: 0.28em; font-weight: 600; margin-bottom: 12px; }
.vr-footer-tagline { font-size: 11px; color: #666; line-height: 1.7; letter-spacing: 0.04em; }
.vr-footer h4 { font-size: 9px; letter-spacing: 0.24em; color: #555; margin-bottom: 16px; font-weight: 600; }
.vr-footer ul { list-style: none; }
.vr-footer li { margin-bottom: 8px; }
.vr-footer li a { font-size: 12px; color: #999; text-decoration: none; letter-spacing: 0.04em; }
.vr-footer li a:hover { color: #fff; }
.vr-footer-bottom {
  border-top: 1px solid #222; padding-top: 24px;
  display: flex; justify-content: space-between; align-items: center;
}
.vr-footer-copy { font-size: 10px; color: #555; letter-spacing: 0.08em; }

/* ─── MOBILE ─── */
@media (max-width: 768px) {
  #vr-nav { padding: 0 20px; }
  .vr-panel-content { padding: 0 24px 48px; }
  #vr-dots { right: 20px; bottom: 20px; }
  #vr-manifesto { padding: 56px 24px; grid-template-columns: 1fr; gap: 24px; }
  .vr-manifesto-logo { max-width: 100px; }
  .vr-sn-content { padding: 0 24px 28px; }
  .vr-products-head { padding: 0 24px 20px; }
  .vr-products-scroll { padding: 0 24px; }
  .vr-prod-card { width: 220px; }
  #vr-tiles { grid-template-columns: 1fr; }
  .vr-tile { aspect-ratio: 4/3; }
  #vr-statement { grid-template-columns: 1fr; gap: 24px; padding: 48px 24px; }
  #vr-gallery { padding: 0 24px 48px; }
  .vr-gallery-item { width: 200px; height: 260px; }
  #vr-footer { padding: 48px 24px 24px; }
  .vr-footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
}
</style>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<div id="vr-root">

<!-- Loader -->
<div id="vr-loader">
  <span id="vr-loader-logo">VOLENU</span>
</div>

<!-- Menu overlay -->
<div id="vr-menu">
  <button id="vr-menu-close">×</button>
  <div class="vr-menu-links">
    <a href="/collections/all">Shop All</a>
    <a href="/collections/new-arrivals">New Arrivals</a>
    <a href="/collections/sale" style="color:#ff4444;">Sale</a>
    <a href="/pages/about">About Us</a>
    <a href="/pages/contact">Contact</a>
  </div>
  <div class="vr-menu-foot">VOLENU © 2025</div>
</div>

<!-- Nav -->
<nav id="vr-nav">
  <a href="/" class="vr-nav-logo">
    <img src="{{ 'volenu-wordmark.png' | asset_url }}" alt="Volenu">
  </a>
  <div class="vr-nav-right">
    <a href="/collections/sale">SALE</a>
    <a href="/cart">CART ({{ cart.item_count }})</a>
    <button id="vr-menu-btn" aria-label="Menu">
      <span></span><span></span>
    </button>
  </div>
</nav>

<!-- Hero panels -->
<section id="vr-hero">

  <!-- Panel 01 — Hero yacht -->
  <div class="vr-panel active" id="vr-p0">
    <img class="vr-panel-img" src="{{ 'hero-banner.png' | asset_url }}" alt="Volenu">
    <div class="vr-panel-overlay"></div>
    <div class="vr-panel-content">
      <div class="vr-panel-num">01</div>
      <div class="vr-panel-title">Explore the Collection</div>
      <a href="/collections/all" class="vr-panel-cta">Shop Now →</a>
    </div>
  </div>

  <!-- Panel 02 — About -->
  <div class="vr-panel" id="vr-p1">
    <img class="vr-panel-img" src="{{ 'hero-banner.png' | asset_url }}" alt="Volenu" style="filter:brightness(0.85) saturate(0.8);">
    <div class="vr-panel-overlay"></div>
    <div class="vr-panel-content">
      <div class="vr-panel-num">02</div>
      <div class="vr-panel-title">A modern expression<br>of precision</div>
      <a href="/pages/about" class="vr-panel-cta">About Us →</a>
    </div>
  </div>

  <!-- Panel 03 — Community -->
  <div class="vr-panel" id="vr-p2">
    <img class="vr-panel-img" src="{{ 'hero-banner.png' | asset_url }}" alt="Volenu" style="filter:brightness(0.65) saturate(0.4);">
    <div class="vr-panel-overlay"></div>
    <div class="vr-panel-content">
      <div class="vr-panel-num">03</div>
      <div class="vr-panel-title">Join the<br>Community</div>
      <a href="https://instagram.com/volenuofficial" class="vr-panel-cta">Follow on Instagram →</a>
    </div>
  </div>

  <!-- Dots -->
  <div id="vr-dots">
    <button class="vr-dot active" onclick="vrGoPanel(0)"></button>
    <button class="vr-dot" onclick="vrGoPanel(1)"></button>
    <button class="vr-dot" onclick="vrGoPanel(2)"></button>
  </div>

  <!-- Scroll hint -->
  <div id="vr-scroll-hint">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
    <span>SCROLL</span>
  </div>

</section>

<!-- Marquee -->
<div class="vr-marquee">
  <div class="vr-marquee-track">
    {% assign marquee_items = "FREE SHIPPING OVER $100 · 30-DAY RETURNS · SITEWIDE 60% OFF · NEW ARRIVALS · PREMIUM QUALITY · WORLDWIDE DELIVERY · FREE SHIPPING OVER $100 · 30-DAY RETURNS · SITEWIDE 60% OFF · NEW ARRIVALS · PREMIUM QUALITY · WORLDWIDE DELIVERY ·" | split: "·" %}
    {% for item in marquee_items %}
      <span>{{ item | strip }} ·</span>
    {% endfor %}
    {% for item in marquee_items %}
      <span>{{ item | strip }} ·</span>
    {% endfor %}
  </div>
</div>

<!-- Manifesto — logo left, text right (Odd Ritual style) -->
<section id="vr-manifesto">
  <img class="vr-manifesto-logo" src="{{ 'volenu-wordmark.png' | asset_url }}" alt="Volenu">
  <div>
    <span class="vr-manifesto-label">( Our Philosophy )</span>
    <p>Born from a shared love of <strong>precision craftsmanship</strong>, rooted in a vision of quality and elegance expressed through what you wear on your wrist. For us, it's about the good times, the <strong>details that matter</strong>, and an appreciation for the culture of horology wherever you go.</p>
  </div>
</section>

<!-- SHOP NOW — hover falling text -->
<section id="vr-shopnow" onclick="window.location='/collections/all'">
  <img id="vr-shopnow-img" src="{{ 'hero-banner.png' | asset_url }}" alt="Shop Now">
  <div class="vr-sn-content">
    <div class="vr-sn-dashes">
      <span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span>
    </div>
    <div class="vr-sn-line">
      <span class="vr-sn-inner">SHOP NOW</span>
    </div>
    <div class="vr-sn-line vr-sn-sub">
      <span class="vr-sn-inner">EXPLORE THE COLLECTION</span>
    </div>
  </div>
</section>

<!-- Featured Products -->
<section id="vr-products">
  <div class="vr-products-head">
    <span class="vr-products-label">( Featured Products )</span>
    <a href="/collections/all" class="vr-products-all">View All</a>
  </div>
  <div class="vr-products-scroll">
    {% for product in collections.all.products limit: 8 %}
      {% assign savings = product.compare_at_price_max | minus: product.price %}
      <div class="vr-prod-card" onclick="window.location='{{ product.url }}'">
        <div class="vr-prod-img">
          {% if product.images.size > 0 %}
            <img class="main-img" src="{{ product.images[0] | img_url: '600x' }}" alt="{{ product.title }}" loading="lazy">
          {% endif %}
          {% if product.images.size > 1 %}
            <img class="hover-img" src="{{ product.images[1] | img_url: '600x' }}" alt="{{ product.title }}" loading="lazy">
          {% else %}
            <img class="hover-img" src="{{ product.images[0] | img_url: '600x' }}" alt="{{ product.title }}" loading="lazy">
          {% endif %}
          {% if savings > 0 %}
            <div class="vr-prod-save">SAVE {{ savings | money }}</div>
          {% endif %}
          <button class="vr-prod-quick" onclick="event.stopPropagation();vrQuickAdd('{{ product.variants.first.id }}')">+ QUICK ADD</button>
        </div>
        <div class="vr-prod-name">{{ product.title | upcase }}</div>
        <div class="vr-prod-prices">
          {% if product.compare_at_price_max > product.price %}
            <span class="vr-prod-orig">{{ product.compare_at_price_max | money }}</span>
            <span class="vr-prod-sale">{{ product.price | money }}</span>
          {% else %}
            <span class="vr-prod-price">{{ product.price | money }}</span>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<section id="vr-tiles">
  <div class="vr-tile">
    <img src="{{ 'hero-banner.png' | asset_url }}" alt="Our Products" style="width:100%;height:100%;object-fit:cover;object-position:left center;">
    <div class="vr-tile-overlay"></div>
    <div class="vr-tile-content">
      <div class="vr-tile-eyebrow">COLLECTION 2025</div>
      <div class="vr-tile-title">Our Products</div>
      <a href="/collections/all" class="vr-tile-cta">Shop now →</a>
    </div>
  </div>
  <div class="vr-tile">
    <img src="{{ 'hero-banner.png' | asset_url }}" alt="Our Story" style="width:100%;height:100%;object-fit:cover;object-position:center;filter:grayscale(0.5);">
    <div class="vr-tile-overlay"></div>
    <div class="vr-tile-content">
      <div class="vr-tile-eyebrow">ABOUT US</div>
      <div class="vr-tile-title">Our Story</div>
      <a href="/pages/about" class="vr-tile-cta">Read more →</a>
    </div>
  </div>
  <div class="vr-tile">
    <img src="{{ 'hero-banner.png' | asset_url }}" alt="Our Community" style="width:100%;height:100%;object-fit:cover;object-position:right center;filter:brightness(0.75);">
    <div class="vr-tile-overlay"></div>
    <div class="vr-tile-content">
      <div class="vr-tile-eyebrow">SOCIAL</div>
      <div class="vr-tile-title">Our Community</div>
      <a href="https://instagram.com/volenuofficial" class="vr-tile-cta">Instagram →</a>
    </div>
  </div>
</section>

<!-- Brand statement -->
<section id="vr-statement">
  <div>
    <div class="vr-statement-label">VOLENU © 2025</div>
    <div class="vr-statement-text">
      Our world is rich in culture, diversity, and heritage — delivering premium watch accessories is how we carry that passion forward, wherever you go.
      <br><br>
      <strong>Made with precision. Built to last.</strong>
    </div>
  </div>
  <div class="vr-statement-num">26</div>
</section>

<!-- Gallery -->
<section id="vr-gallery">
  <div class="vr-gallery-head">
    <span class="vr-gallery-label">( Gallery )</span>
    <span class="vr-gallery-hint">Swipe →</span>
  </div>
  <div class="vr-gallery-scroll" id="vr-gallery-scroll">
    {% for product in collections.all.products limit: 7 %}
      {% if product.featured_image %}
      <div class="vr-gallery-item">
        <img src="{{ product.featured_image | img_url: '500x' }}" alt="{{ product.title }}" loading="lazy">
      </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<!-- Footer -->
