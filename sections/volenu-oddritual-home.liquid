(function() {

  // ── Intro animation — show only once per session ──
  var vrLoader = document.getElementById('vr-loader');
  function vrHideLoader() {
    vrLoader.classList.add('out');
    setTimeout(function() { vrLoader.classList.add('done'); }, 900);
  }
  if (sessionStorage.getItem('vr-loaded')) {
    vrLoader.classList.add('done');
  } else {
    sessionStorage.setItem('vr-loaded', '1');
    setTimeout(vrHideLoader, 1400);
    window.addEventListener('load', function() {
      setTimeout(vrHideLoader, 800);
    });
  }

  // ── Cart drawer trigger ──
  var vrCartBtn = document.getElementById('vr-cart-btn');
  function vrOpenCartDrawer() {
    var cartDrawer = document.querySelector('cart-drawer');
    if (cartDrawer && typeof cartDrawer.open === 'function') {
      cartDrawer.open(vrCartBtn);
    }
  }
  if (vrCartBtn) {
    vrCartBtn.addEventListener('click', function(e) {
      e.preventDefault();
      vrOpenCartDrawer();
    });
  }
  // Auto-open if redirected from /cart
  if (window.location.search.indexOf('open_cart=1') !== -1) {
    window.history.replaceState({}, '', '/');
    setTimeout(vrOpenCartDrawer, 600);
  }

  // ── Nav Dropdowns ──
  window.vrToggleDrop = function(id) {
    var item = document.getElementById('vr-drop-' + id);
    var isOpen = item.classList.contains('open');
    document.querySelectorAll('.vr-nav-item').forEach(function(el){ el.classList.remove('open'); });
    if (!isOpen) item.classList.add('open');
  };
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.vr-nav-item')) {
      document.querySelectorAll('.vr-nav-item').forEach(function(el){ el.classList.remove('open'); });
    }
  });

  // ── Menu ──
  var menuBtnMobile = document.getElementById('vr-menu-btn-mobile');
  if (menuBtnMobile) {
    menuBtnMobile.addEventListener('click', function() {
      document.getElementById('vr-menu').classList.add('open');
      // Move BUCKS widget into menu footer on mobile
      setTimeout(function() {
        var slot = document.getElementById('vr-menu-currency-slot');
        if (!slot || slot.children.length > 0) return;
        var selectors = [
          '[class*="bucks-currency"]',
          '[id*="currency-switcher"]',
          '[id*="bucks"]',
          '.boost-currency-switcher',
          '[data-currency-selector]',
          '[class*="currency-selector"]',
          '[class*="currency-switcher"]'
        ];
        for (var i = 0; i < selectors.length; i++) {
          var widget = document.querySelector(selectors[i]);
          if (widget) {
            var clone = widget.cloneNode(true);
            clone.style.cssText = '';
            slot.appendChild(clone);
            return;
          }
        }
        // fallback: show nav currency content
        var navCurrency = document.getElementById('vr-currency-wrap');
        if (navCurrency) slot.innerHTML = navCurrency.innerHTML;
      }, 800);
    });
  }
  // legacy desktop btn (hidden but keep for safety)
  var menuBtnOld = document.getElementById('vr-menu-btn');
  if (menuBtnOld) {
    menuBtnOld.addEventListener('click', function() {
      document.getElementById('vr-menu').classList.add('open');
    });
  }
  document.getElementById('vr-menu-close').addEventListener('click', function() {
    document.getElementById('vr-menu').classList.remove('open');
  });

  // ── Hero panel rotation ──
  var vrPanel = 0;
  var vrPanels = document.querySelectorAll('.vr-panel');
  var vrDots = document.querySelectorAll('.vr-dot');

  window.vrGoPanel = function(n) {
    vrPanels[vrPanel].classList.remove('active');
    vrDots[vrPanel].classList.remove('active');
    vrPanel = n;
    vrPanels[vrPanel].classList.add('active');
    vrDots[vrPanel].classList.add('active');
  };

  // Auto-advance every 5s
  setInterval(function() {
    vrGoPanel((vrPanel + 1) % vrPanels.length);
  }, 5000);

  // ── SHOP NOW proximity trigger — bottom-left corner ──
  var vrSn = document.getElementById('vr-sn');
  var vrHero = document.getElementById('vr-hero');
  if (vrSn && vrHero) {
    vrHero.addEventListener('mousemove', function(e) {
      var rect = vrHero.getBoundingClientRect();
      // Proximity zone: bottom-left corner of hero
      var distX = e.clientX - rect.left;
      var distY = rect.bottom - e.clientY;
      var near = distX < 400 && distY < 200;
      vrHero.classList.toggle('sn-near', near);
    });
    vrHero.addEventListener('mouseleave', function() {
      vrHero.classList.remove('sn-near');
    });
  }

  // ── Nav scroll color switch ──
  var vrNav = document.getElementById('vr-nav');
  window.addEventListener('scroll', function() {
    vrNav.classList.toggle('scrolled', window.scrollY > window.innerHeight * 0.85);
    var hint = document.getElementById('vr-scroll-hint');
    if (hint) hint.style.opacity = window.scrollY > 60 ? '0' : '1';
  }, { passive: true });

  // ── Scroll reveal ──
  var vrRevealEls = [
    document.getElementById('vr-manifesto'),
    document.getElementById('vr-statement'),
    document.getElementById('vr-gallery')
  ].concat(
    Array.from(document.querySelectorAll('.vr-prod-card')),
    Array.from(document.querySelectorAll('.vr-tile'))
  );

  var vrObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        vrObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  vrRevealEls.forEach(function(el) {
    if (el) vrObserver.observe(el);
  });

  // ── Product scroll — mouse drag ──
  (function() {
    var ps = document.querySelector('.vr-products-scroll');
    var track = document.getElementById('vr-prod-track');
    if (!ps || !track) return;
    var isDragging = false, startX = 0, savedOffset = 0;
    ps.addEventListener('mousedown', function(e) {
      isDragging = true; ps.classList.add('is-dragging');
      startX = e.pageX;
      var mat = new DOMMatrix(window.getComputedStyle(track).transform);
      savedOffset = mat.m41 || 0;
    });
    document.addEventListener('mouseup', function() {
      if (!isDragging) return;
      isDragging = false; ps.classList.remove('is-dragging');
      track.style.animation = ''; track.style.transform = '';
    });
    document.addEventListener('mousemove', function(e) {
      if (!isDragging) return;
      e.preventDefault();
      var dx = e.pageX - startX;
      track.style.animation = 'none';
      track.style.transform = 'translateX(' + (savedOffset + dx) + 'px)';
    });
    // Touch
    ps.addEventListener('touchstart', function(e) { isDragging = true; startX = e.touches[0].pageX; var mat = new DOMMatrix(window.getComputedStyle(track).transform); savedOffset = mat.m41 || 0; }, { passive: true });
    ps.addEventListener('touchmove', function(e) { if (!isDragging) return; var dx = e.touches[0].pageX - startX; track.style.animation = 'none'; track.style.transform = 'translateX(' + (savedOffset + dx) + 'px)'; }, { passive: true });
    ps.addEventListener('touchend', function() { isDragging = false; track.style.animation = ''; track.style.transform = ''; });
  })();


  window.vrQuickAdd = function(variantId) {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    }).then(function() {
      window.location.href = '/cart';
    });
  };

  // ── Sale popup ──
  (function() {
    // Only show once per session
    if (sessionStorage.getItem('vr-popup-seen')) return;

    var popup = document.getElementById('vr-sale-popup');
    var closeBtn = document.getElementById('vr-sale-popup-close');
    if (!popup) return;

    // Show after 3 seconds
    setTimeout(function() {
      popup.classList.add('visible');
    }, 3000);

    // Close button
    closeBtn.addEventListener('click', function() {
      popup.classList.remove('visible');
      sessionStorage.setItem('vr-popup-seen', '1');
    });

    // Countdown timer
    function updatePopupTimer() {
      var now = new Date();
      var midnight = new Date();
      midnight.setHours(23, 59, 59, 0);
      var diff = midnight - now;
      if (diff < 0) diff = 0;
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      var pad = function(n) { return n < 10 ? '0' + n : '' + n; };
      var eh = document.getElementById('vr-sp-h');
      var em = document.getElementById('vr-sp-m');
      var es = document.getElementById('vr-sp-s');
      if (eh) eh.textContent = pad(h);
      if (em) em.textContent = pad(m);
      if (es) es.textContent = pad(s);
    }
    updatePopupTimer();
    setInterval(updatePopupTimer, 1000);
  })();

  // ── Sale popup ──
  (function() {
    if (sessionStorage.getItem('vr-popup-shown')) return;
    var popup = document.getElementById('vr-sale-popup');
    var overlay = document.getElementById('vr-sale-popup-overlay');
    var closeBtn = document.getElementById('vr-sale-popup-close');
    if (!popup) return;

    function closePopup() {
      popup.classList.remove('open');
      sessionStorage.setItem('vr-popup-shown', '1');
    }

    function updatePopupTimer() {
      var now = new Date();
      var midnight = new Date();
      midnight.setHours(23, 59, 59, 0);
      var diff = midnight - now;
      if (diff < 0) diff = 0;
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      var pad = function(n) { return n < 10 ? "0" + n : "" + n; };
      var ph = document.getElementById("vr-pt-h");
      var pm = document.getElementById("vr-pt-m");
      var ps = document.getElementById("vr-pt-s");
      if (ph) ph.textContent = pad(h);
      if (pm) pm.textContent = pad(m);
      if (ps) ps.textContent = pad(s);
    }

    setTimeout(function() {
      popup.classList.add("open");
      updatePopupTimer();
      setInterval(updatePopupTimer, 1000);
    }, 2500);

    if (closeBtn) closeBtn.addEventListener("click", closePopup);
    if (overlay) overlay.addEventListener("click", closePopup);

    function revealDiscount() {
      var step1 = document.getElementById("vr-popup-step1");
      var step2 = document.getElementById("vr-popup-step2");
      if (step1) step1.style.display = "none";
      if (step2) step2.style.display = "block";
    }

    var submitBtn = document.getElementById("vr-popup-submit");
    if (submitBtn) {
      submitBtn.addEventListener("click", function() {
        var emailEl = document.getElementById("vr-popup-email");
        var errEl = document.getElementById("vr-popup-email-error");
        var val = emailEl ? emailEl.value.trim() : "";
        // Validate email
        if (!val || !val.includes("@") || !val.includes(".")) {
          if (errEl) errEl.style.display = "block";
          if (emailEl) emailEl.style.borderColor = "#c0392b";
          return;
        }
        if (errEl) errEl.style.display = "none";
        // Subscribe to Shopify email list
        fetch("/contact", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: "form_type=customer&email=" + encodeURIComponent(val) + "&contact[tags]=newsletter"
        }).catch(function() {});
        revealDiscount();
      });
    }

    var noThanks = document.getElementById("vr-popup-nothanks");
    if (noThanks) noThanks.addEventListener("click", closePopup);
  })();

  // ── Strip timer ──
  (function() {
    function vrStripTimer() {
      var now = new Date(), midnight = new Date();
      midnight.setHours(23,59,59,0);
      var diff = midnight - now; if (diff < 0) diff = 0;
      var pad = function(n){return n<10?"0"+n:""+n;};
      var el = document.getElementById("vr-strip-timer");
      if (el) el.textContent = pad(Math.floor(diff/3600000))+":"+pad(Math.floor((diff%3600000)/60000))+":"+pad(Math.floor((diff%60000)/1000));
    }
    vrStripTimer(); setInterval(vrStripTimer, 1000);
  })();

  // ── Announcement bar — auto-rotate + arrows ──
  (function() {
    var msgs = document.querySelectorAll('.vr-hs-msg');
    if (!msgs.length) return;
    var current = 0;
    var timer;

    function show(idx) {
      msgs[current].classList.remove('active');
      current = (idx + msgs.length) % msgs.length;
      msgs[current].classList.add('active');
    }

    function startTimer() {
      clearInterval(timer);
      timer = setInterval(function() { show(current + 1); }, 4000);
    }

    document.getElementById('vr-hs-next').addEventListener('click', function() {
      show(current + 1); startTimer();
    });
    document.getElementById('vr-hs-prev').addEventListener('click', function() {
      show(current - 1); startTimer();
    });

    startTimer();
  })();

  // ── Lenis smooth scroll — lerp 0.03 (Odd Ritual speed) ──
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js';
    s.onload = function() {
      var lenis = new Lenis({ lerp: 0.08, smoothWheel: true, wheelMultiplier: 1.0 });
      function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);
    };
    document.head.appendChild(s);
  })();

  var gs = document.getElementById('vr-gallery-scroll');
  if (gs) {
    var isDragging = false, startX, scrollLeft;
    gs.addEventListener('mousedown', function(e) {
      isDragging = true; startX = e.pageX - gs.offsetLeft; scrollLeft = gs.scrollLeft;
    });
    gs.addEventListener('mouseleave', function() { isDragging = false; });
    gs.addEventListener('mouseup', function() { isDragging = false; });
    gs.addEventListener('mousemove', function(e) {
      if (!isDragging) return;
      e.preventDefault();
      gs.scrollLeft = scrollLeft - (e.pageX - gs.offsetLeft - startX);
    });
  }

})();
</script>

{% schema %}
{
  "name": "Volenu Odd Ritual Home",
  "settings": [],
  "presets": [{ "name": "Volenu Odd Ritual Home" }]
}
{% endschema %}
