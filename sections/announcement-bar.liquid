<style>
  .volenu-ticker-wrap {
    background: #000;
    overflow: hidden;
    white-space: nowrap;
    padding: 9px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .volenu-ticker-track {
    display: inline-flex;
    animation: volenu-ticker 35s linear infinite;
  }
  .volenu-ticker-track span {
    color: rgba(255,255,255,0.45);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0 28px;
  }
  .volenu-ticker-track span::before {
    content: "◆";
    margin-right: 28px;
    opacity: 0.2;
    font-size: 7px;
  }
  @keyframes volenu-ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .volenu-countdown-bar {
    background: #111;
    color: #fff;
    text-align: center;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .volenu-timer { display: flex; gap: 4px; align-items: center; }
  .volenu-timer-block {
    background: #fff;
    color: #000;
    border-radius: 3px;
    padding: 2px 8px;
    font-weight: 800;
    font-size: 14px;
    min-width: 32px;
    text-align: center;
  }
  .volenu-timer-sep { font-weight: 800; opacity: 0.4; }
</style>

<div class="volenu-ticker-wrap">
  <div class="volenu-ticker-track">
    <span>Free Worldwide Shipping</span>
    <span>2 Year Warranty</span>
    <span>50,000+ Collectors</span>
    <span>Aviation EVA Foam</span>
    <span>TSA Approved</span>
    <span>Scratch-Free Suede</span>
    <span>30 Day Returns</span>
    <span>Free Worldwide Shipping</span>
    <span>2 Year Warranty</span>
    <span>50,000+ Collectors</span>
    <span>Aviation EVA Foam</span>
    <span>TSA Approved</span>
    <span>Scratch-Free Suede</span>
    <span>30 Day Returns</span>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "presets": [{ "name": "Announcement Bar" }]
}
{% endschema %}
