    { "type": "text", "id": "desc_bullet_1", "label": "Bullet 1" },
    { "type": "text", "id": "desc_bullet_2", "label": "Bullet 2" },
    { "type": "text", "id": "desc_bullet_3", "label": "Bullet 3" }
  ],
  "presets": [{ "name": "Volenu Parijan Product" }]
}
{% endschema %}
