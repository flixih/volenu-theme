<!-- You May Also Like -->
<div class="vpp-related">
  <div class="vpp-related-title">YOU MAY ALSO LIKE</div>
  <div class="vpp-related-grid">
    {% assign related = collections.all.products | where: 'id', product.id %}
    {% assign shown = 0 %}
    {% for p in collections.all.products %}
      {% if p.id != product.id and shown < 8 %}
        {% assign savings = p.compare_at_price_max | minus: p.price %}
        <div class="vpp-related-card" onclick="window.location='{{ p.url }}'">
          <div class="vpp-related-img">
            {% if p.featured_image %}
              <img src="{{ p.featured_image | img_url: '400x' }}" alt="{{ p.title }}" loading="lazy">
            {% else %}
              <div style="width:100%;height:100%;background:#f0f0f0;"></div>
            {% endif %}
            {% if savings > 0 %}
              <div class="vpp-related-save">SAVE {{ savings | money }}</div>
            {% endif %}
          </div>
          <div class="vpp-related-info">
            <div class="vpp-related-name">{{ p.title | upcase }}</div>
            <div class="vpp-related-prices">
              {% if p.compare_at_price_max > p.price %}
                <span class="vpp-related-orig">{{ p.compare_at_price_max | money }}</span>
                <span class="vpp-related-sale">{{ p.price | money }}</span>
              {% else %}
                <span class="vpp-related-sale">{{ p.price | money }}</span>
              {% endif %}
            </div>
            {% assign color_opt = p.options_by_name['Color'] %}
            {% if color_opt %}
            <div class="vpp-related-swatches">
              {% for val in color_opt.values limit: 4 %}
                {% assign cl = val | downcase | replace: ' ', '' %}
                {% assign sc = '#888' %}
                {% if cl == 'black' %}{% assign sc = '#1a1a1a' %}{% elsif cl == 'white' or cl == 'cream' %}{% assign sc = '#f5f5f0' %}{% elsif cl == 'navy' %}{% assign sc = '#1a2744' %}{% elsif cl == 'beige' or cl == 'sand' %}{% assign sc = '#d4c5a9' %}{% elsif cl == 'brown' %}{% assign sc = '#8b6347' %}{% elsif cl == 'green' %}{% assign sc = '#5c6e2e' %}{% elsif cl == 'blue' %}{% assign sc = '#6aaccc' %}{% endif %}
                <div class="vpp-related-swatch" style="background:{{ sc }};"></div>
              {% endfor %}
              {% if color_opt.values.size > 4 %}<span style="font-size:9px;color:#666;"> +{{ color_opt.values.size | minus: 4 }}</span>{% endif %}
            </div>
            {% endif %}
          </div>
        </div>
        {% assign shown = shown | plus: 1 %}
      {% endif %}
    {% endfor %}
  </div>
</div>

<!-- Testimonial -->
<div class="vpp-testimonial">
  <div class="vpp-testimonial-label">OUR CUSTOMERS LOVE US</div>
  <div class="vpp-testimonial-text">"Volenu is the definition of precision engineering! I feel confident knowing my watches are protected in a vault built to last."</div>
  <div class="vpp-testimonial-author">— Marcus T., New York</div>
</div>

<!-- Sticky ATC -->
<div class="vpp-sticky" id="vpp-sticky">
