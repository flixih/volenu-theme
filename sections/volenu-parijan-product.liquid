    <div class="vpp-sticky-img">
      <img src="{{ product.featured_image | img_url: '120x' }}" alt="{{ product.title }}">
    </div>
    {% endif %}
    <div>
      <div class="vpp-sticky-name">{{ product.title | upcase | truncate: 40 }}</div>
      <div class="vpp-sticky-price">{{ product.price | money }}</div>
    </div>
  </div>
  <button class="vpp-sticky-btn" onclick="vppAddToCart()">ADD TO CART</button>
</div>

</div><!-- /vpp-root -->

<script>
  // Image gallery with slide animation
  const vppImgs = [{% for img in product.images %}"{{ img | img_url: '800x' }}"{% unless forloop.last %},{% endunless %}{% endfor %}];
  let vppIdx = 0;

  function vppSetImg(i, dir) {
    const img = document.getElementById('vpp-big-img');
    if (img) {
      img.classList.remove('slide-left', 'slide-right');
      void img.offsetWidth; // reflow
      if (dir === 1) img.classList.add('slide-left');
      else if (dir === -1) img.classList.add('slide-right');
      img.src = vppImgs[i];
    }
    vppIdx = i;
    document.querySelectorAll('.vpp-thumb').forEach((t, j) => t.classList.toggle('active', j === i));
  }

  function vppSlide(dir) {
    vppSetImg((vppIdx + dir + vppImgs.length) % vppImgs.length, dir);
  }

  // Size select
  function vppSelectSize(btn, val) {
    document.querySelectorAll('.vpp-sizes .vpp-size:not([title])').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('vpp-selected-size') && (document.getElementById('vpp-selected-size').textContent = val);
  }

  // Color select
  function vppSelectColor(btn, val) {
    document.querySelectorAll('.vpp-size[title]').forEach(b => { b.style.borderColor = '#ddd'; b.classList.remove('active'); });
    btn.style.borderColor = '#111';
    btn.classList.add('active');
    document.getElementById('vpp-selected-color') && (document.getElementById('vpp-selected-color').textContent = val);
  }

  // Buy option
  let vppQty = 1;
  function vppSelectBuy(el, qty) {
    document.querySelectorAll('.vpp-buy-opt').forEach(o => o.classList.remove('active'));
    el.classList.add('active');
    vppQty = qty;
  }

  // Add to cart
  function vppAddToCart() {
    const variantId = {{ product.variants.first.id }};
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: vppQty })
    }).then(() => { window.location.href = '/cart'; });
  }

  // Accordion
  function vppToggle(btn) {
    const item = btn.closest('.vpp-accord-item');
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.vpp-accord-item').forEach(i => i.classList.remove('open'));
    if (!wasOpen) item.classList.add('open');
  }

  // Sticky ATC
  const vppSticky = document.getElementById('vpp-sticky');
  const vppAtcBtn = document.querySelector('.vpp-atc');
  if (vppAtcBtn && vppSticky) {
    window.addEventListener('scroll', () => {
      const rect = vppAtcBtn.getBoundingClientRect();
      vppSticky.classList.toggle('show', rect.bottom < 0);
    }, { passive: true });
  }
</script>

{% schema %}
{
