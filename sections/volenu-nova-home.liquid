<!-- LOADER -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;800&display=swap');
@keyframes vnDL{0%{opacity:0;transform:translateX(32px)}30%{opacity:1}100%{opacity:1;transform:translateX(0)}}
@keyframes vnDR{0%{opacity:0;transform:translateX(-32px)}30%{opacity:1}100%{opacity:1;transform:translateX(0)}}
@keyframes vnSepIn{0%{opacity:0;transform:scaleY(0)}100%{opacity:1;transform:scaleY(1)}}
@keyframes vnSU{0%{transform:translate3d(0,0,0)}100%{transform:translate3d(0,-110%,0)}}
#vnLoader{position:fixed;top:0;left:0;right:0;bottom:0;z-index:99999;background:#f0efe9;display:flex;align-items:center;justify-content:center;}
#vnLoader.out{animation:vnSU 1s cubic-bezier(.87,0,.13,1) forwards;}
#vnLWrap{display:flex;align-items:center;font-size:23px;white-space:nowrap;font-family:'Outfit',sans-serif;}
#vnLBold{font-weight:700;color:#111;letter-spacing:-.01em;opacity:0;animation:vnDL 1.1s cubic-bezier(.16,1,.3,1) 1.05s forwards;}
#vnLSep{display:inline-block !important;width:2.5px !important;height:22px !important;background:#333 !important;margin:0 12px;flex-shrink:0;opacity:0;transform:scaleY(0);transform-origin:center;animation:vnSepIn .35s cubic-bezier(.16,1,.3,1) .8s forwards;vertical-align:middle;}
#vnLLight{font-weight:300;color:#777;letter-spacing:.01em;opacity:0;animation:vnDR 1s cubic-bezier(.16,1,.3,1) 2.2s forwards;}
</style>
<div id="vnLoader">
  <div id="vnLWrap">
    <span id="vnLBold">VOLENU</span>
    <span id="vnLSep"></span>
    <span id="vnLLight">Cases</span>
  </div>
</div>

<!-- ── OUR NAV ──────────────────────────────── -->
<style>
.vn-topnav{
  position:fixed;top:0;left:0;right:0;z-index:9000;
  background:#fff;
  border-bottom:1px solid #e8e4dc;
}
.vn-topnav-main{
  display:grid;grid-template-columns:1fr auto 1fr;
  align-items:center;padding:0 48px;height:72px;
}
.vn-topnav-left{display:flex;gap:32px;list-style:none}
.vn-topnav-left a{
  font-family:'Jost',sans-serif;font-size:11px;letter-spacing:.12em;
  text-transform:uppercase;color:#666;text-decoration:none;transition:color .2s;
}
.vn-topnav-left a:hover{color:#111}
.vn-topnav-logo a{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:30px;font-weight:600;letter-spacing:.18em;
  color:#111;text-decoration:none;text-transform:uppercase;
}
.vn-topnav-right{
  display:flex;align-items:center;justify-content:flex-end;gap:24px;
}
.vn-topnav-right a{
  font-family:'Jost',sans-serif;font-size:11px;letter-spacing:.1em;
  text-transform:uppercase;color:#666;text-decoration:none;transition:color .2s;
}
.vn-topnav-right a:hover{color:#111}
.vn-topnav-cart{
  font-family:'Jost',sans-serif;font-size:11px;letter-spacing:.1em;
  text-transform:uppercase;color:#111;text-decoration:none;
}
/* Category row */
.vn-catnav{
  border-top:1px solid #e8e4dc;
  display:flex;align-items:center;justify-content:center;
  gap:48px;padding:0 48px;height:40px;
  background:#fff;
}
.vn-catnav a{
  font-family:'Jost',sans-serif;font-size:10px;font-weight:500;
  letter-spacing:.2em;text-transform:uppercase;
  color:#555;text-decoration:none;transition:color .2s;white-space:nowrap;
}
.vn-catnav a:hover{color:#111}
/* Push page content below fixed nav */
.vn-nav-spacer{height:112px}
@media(max-width:768px){
  .vn-topnav-main{padding:0 16px}
  .vn-topnav-left{display:none}
  .vn-catnav{display:none}
  .vn-nav-spacer{height:72px}
}
</style>
<div class="vn-topnav">
  <div class="vn-topnav-main">
    <ul class="vn-topnav-left">
      <li><a href="/collections/all">Shop All</a></li>
      <li><a href="/collections/all">Watch Cases</a></li>
      <li><a href="/collections/all">New Arrivals</a></li>
    </ul>
    <div class="vn-topnav-logo"><a href="/">Volenu</a></div>
    <div class="vn-topnav-right">
      <a href="/account">Account</a>
      <a href="/search">Search</a>
      <a href="/cart" class="vn-topnav-cart">Cart ({{ cart.item_count }})</a>
    </div>
  </div>
  <nav class="vn-catnav">
  <a href="/collections/all">Watch Cases</a>
  <a href="/collections/all">Watch Winders</a>
  <a href="/collections/all">New Arrivals</a>
  <a href="/collections/all">Best Sellers</a>
  <a href="/collections/all">Accessories</a>
  <a href="/pages/contact">Contact</a>
</nav>

<!-- ── NAV ──────────────────────────────── -->
<!-- ── HERO VIDEO ────────────────────────────── -->
<style>
.vn-hero-wrap{
  position:relative;
  height:200vh;
}
.vn-hero-sticky{
  position:sticky;
  top:0;
  height:100vh;
  overflow:hidden;
  background:#111;
}
.vn-hero-video{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  will-change:transform;
}
.vn-hero-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.5) 100%);
  z-index:1;
}
.vn-hero-content{
  position:absolute;
  bottom:15%;left:50%;
  transform:translateX(-50%);
  z-index:2;text-align:center;
  width:100%;
  will-change:transform,opacity;
}
.vn-hero-content h1{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:clamp(14px,2vw,18px);
  font-weight:400;letter-spacing:.4em;
  text-transform:uppercase;color:rgba(255,255,255,.7);
  margin-bottom:16px;
  opacity:0;animation:vhIn .8s .3s both;
}
.vn-hero-content h2{
  font-family:'Cormorant Garamond',Georgia,serif;
  font-size:clamp(48px,8vw,96px);
  font-weight:300;line-height:.9;
  color:#fff;letter-spacing:.08em;text-transform:uppercase;
  margin-bottom:36px;
  opacity:0;animation:vhIn 1s .6s both;
}
.vn-hero-content a{
  display:inline-block;
  font-family:'Jost',sans-serif;font-size:11px;
  font-weight:500;letter-spacing:.22em;text-transform:uppercase;
  background:rgba(201,168,76,0.9);color:#fff;
  padding:14px 44px;text-decoration:none;
  transition:background .3s;
  opacity:0;animation:vhIn .8s .9s both;
}
.vn-hero-content a:hover{background:rgba(201,168,76,1)}
.vn-scroll-cue{
  position:absolute;bottom:32px;left:50%;
  transform:translateX(-50%);
  z-index:2;display:flex;flex-direction:column;
  align-items:center;gap:10px;
  opacity:0;animation:vhIn .8s 1.2s both;
}
.vn-scroll-cue span{
  font-family:'Jost',sans-serif;font-size:10px;
  letter-spacing:.25em;text-transform:uppercase;
  color:rgba(255,255,255,.5);
}
.vn-scroll-cue-line{
  width:1px;height:44px;
  background:linear-gradient(rgba(255,255,255,.6),transparent);
  animation:scPulse 2s infinite;
}
@keyframes vhIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes scPulse{0%,100%{opacity:.7}50%{opacity:.2}}
</style>

<div class="vn-hero-wrap" id="vhWrap">
  <div class="vn-hero-sticky">
    <video
      class="vn-hero-video"
      id="vhVideo"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      src="{{ 'hero-video.mp4' | asset_url }}"
    ></video>
    <div class="vn-hero-overlay"></div>
    <div class="vn-hero-content" id="vhContent">
      <h1>Discover the craftsmanship behind every case</h1>
      <h2>Engineered for<br>the Exceptional</h2>
      <a href="/collections/all">Shop the Collection</a>
    </div>
    <div class="vn-scroll-cue">
      <span>Scroll</span>
      <div class="vn-scroll-cue-line"></div>
    </div>
  </div>
</div>

<script>
(function(){
  var wrap = document.getElementById('vhWrap');
  var content = document.getElementById('vhContent');
  var video = document.getElementById('vhVideo');

  // Sync video playback with scroll
  window.addEventListener('scroll', function(){
    if(!wrap) return;
    var rect = wrap.getBoundingClientRect();
    var wrapH = wrap.offsetHeight;
    var scrolled = -rect.top;
    var progress = Math.max(0, Math.min(1, scrolled / (wrapH - window.innerHeight)));

    // Parallax: content moves up as you scroll
    if(content){
      var moveY = scrolled * 0.3;
      var fade = Math.max(0, 1 - progress * 2);
      content.style.transform = 'translateX(-50%) translateY(-' + moveY + 'px)';
      content.style.opacity = fade;
    }

    // Video: scrub through based on scroll position (if not looping you want this)
    // Since video is looping we just let it play — parallax is the scroll effect
  }, {passive:true});
})();
</script>

