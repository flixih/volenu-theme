<script>
(function(){
  window.addEventListener('load',function(){
    setTimeout(function(){document.getElementById('vnLoader').classList.add('vn-loaded')},1800);
  });
  var cx=0,cy=0,rx=0,ry=0;
  var c=document.getElementById('vnCursor'),r=document.getElementById('vnRing');
  if(!c||!r)return;
  document.addEventListener('mousemove',function(e){cx=e.clientX;cy=e.clientY;c.style.left=cx+'px';c.style.top=cy+'px'});
  (function animRing(){rx+=(cx-rx)*.12;ry+=(cy-ry)*.12;r.style.left=rx+'px';r.style.top=ry+'px';requestAnimationFrame(animRing)})();
  document.querySelectorAll('a,button').forEach(function(el){
    el.addEventListener('mouseenter',function(){r.classList.add('vn-hover')});
    el.addEventListener('mouseleave',function(){r.classList.remove('vn-hover')});
  });
  var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('vn-visible')})},{threshold:0.08});
  document.querySelectorAll('.vn-reveal').forEach(function(el){obs.observe(el)});
})();
</script>

