<!-- LOADER -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;800&display=swap');
@keyframes vnDL{0%{opacity:0;transform:translateX(32px)}30%{opacity:1}100%{opacity:1;transform:translateX(0)}}
@keyframes vnDR{0%{opacity:0;transform:translateX(-32px)}30%{opacity:1}100%{opacity:1;transform:translateX(0)}}
@keyframes vnSepIn{0%{opacity:0;transform:scaleY(0)}100%{opacity:1;transform:scaleY(1)}}
@keyframes vnSU{0%{transform:translate3d(0,0,0)}100%{transform:translate3d(0,-110%,0)}}
#vnLoader{position:fixed;top:0;left:0;right:0;bottom:0;z-index:99999;background:#f0efe9;display:flex;align-items:center;justify-content:center;}
#vnLoader.out{animation:vnSU 1s cubic-bezier(.87,0,.13,1) forwards;}
#vnLWrap{display:flex;align-items:center;font-size:23px;white-space:nowrap;font-family:'Outfit',sans-serif;}
#vnLBold{font-weight:700;color:#111;letter-spacing:-.01em;opacity:0;animation:vnDL 1.1s cubic-bezier(.16,1,.3,1) 1.05s forwards;}
#vnLSep{display:inline-block !important;width:2.5px !important;height:22px !important;background:#333 !important;margin:0 12px;flex-shrink:0;opacity:0;transform:scaleY(0);transform-origin:center;animation:vnSepIn .35s cubic-bezier(.16,1,.3,1) .8s forwards;vertical-align:middle;}
#vnLLight{font-weight:300;color:#777;letter-spacing:.01em;opacity:0;animation:vnDR 1s cubic-bezier(.16,1,.3,1) 2.2s forwards;}
</style>
<div id="vnLoader">
  <div id="vnLWrap">
    <span id="vnLBold">VOLENU</span>
    <span id="vnLSep"></span>
    <span id="vnLLight">Cases</span>
  </div>
</div>

