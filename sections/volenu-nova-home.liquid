    <span class="ts-logo-brand" style="font-family:Georgia,serif;font-size:16px;font-weight:400;color:#1a1a1a;letter-spacing:2px;">Bell&Ross</span>
    <span class="ts-logo-brand" style="font-family:Georgia,serif;font-style:italic;font-size:22px;color:#1a1a1a;">Cartier</span>
    <span class="ts-logo-brand" style="font-family:Arial Black,sans-serif;font-size:18px;font-weight:900;color:#006039;letter-spacing:3px;">ROLEX</span>
    <span class="ts-logo-brand" style="font-family:Arial,sans-serif;font-size:16px;font-weight:400;color:#1a1a1a;letter-spacing:4px;">PANERAI</span>
    <span class="ts-logo-brand" style="font-family:Arial,sans-serif;font-size:16px;font-weight:700;color:#1a1a1a;letter-spacing:2px;">HUBLOT</span>
    <span class="ts-logo-brand" style="font-family:Georgia,serif;font-size:22px;font-weight:400;color:#cc0000;letter-spacing:1px;">Ω OMEGA</span>
    <span class="ts-logo-brand" style="font-family:Georgia,serif;font-size:14px;font-weight:400;color:#1a1a1a;letter-spacing:1px;">AUDEMARS PIGUET</span>
