<!-- LOADER -->
<style>
@keyframes vnBlink{0%,100%{opacity:1}49%{opacity:1}50%,99%{opacity:0}}
@keyframes vnSU{0%{transform:translate3d(0,0,0)}100%{transform:translate3d(0,-110%,0)}}
#vnLoader{position:fixed;top:0;left:0;right:0;bottom:0;z-index:99999;background:#f0efe9;display:flex;align-items:center;justify-content:center;}
#vnLoader.out{animation:vnSU .9s cubic-bezier(.87,0,.13,1) forwards;}
#vnLWrap{font-size:21px;display:flex;align-items:center;white-space:nowrap;font-family:Barlow,sans-serif;}
#vnLBold{font-weight:800;color:#1a1a1a;letter-spacing:.01em;}
#vnLSep{font-weight:300;color:#999;margin:0 9px;opacity:0;}
#vnLLight{font-weight:300;color:#666;letter-spacing:.01em;}
#vnLCursor{display:inline-block;width:1.5px;height:1.1em;background:#1a1a1a;margin-left:1px;vertical-align:middle;animation:vnBlink .8s step-end infinite;}
</style>
