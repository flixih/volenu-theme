      <div class="vn-sg vn-reveal vn-delay-1">
        <div class="vn-sg-title">Display & Control</div>
        <div class="vn-sr"><span>Panels</span><span>2 × LCD</span></div>
        <div class="vn-sr"><span>Control Type</span><span>Button Interface</span></div>
        <div class="vn-sr"><span>Memory</span><span>Auto-Resume</span></div>
        <div class="vn-sr"><span>Power</span><span>AC Adapter Included</span></div>
      </div>
      <div class="vn-sg vn-reveal">
        <div class="vn-sg-title">Capacity & Fit</div>
        <div class="vn-sr"><span>Watch Capacity</span><span>4 Timepieces</span></div>
        <div class="vn-sr"><span>Watch Diameter</span><span>40mm – 57mm</span></div>
        <div class="vn-sr"><span>Cushion Type</span><span>Black Velvet Pillow</span></div>
        <div class="vn-sr"><span>Compatibility</span><span>All Automatic Watches</span></div>
      </div>
      <div class="vn-sg vn-reveal vn-delay-1">
        <div class="vn-sg-title">Design & Materials</div>
        <div class="vn-sr"><span>Exterior Finish</span><span>Piano Black Lacquer</span></div>
        <div class="vn-sr"><span>Side Material</span><span>Carbon Fibre Texture</span></div>
        <div class="vn-sr"><span>Door</span><span>Tempered Glass + Key Lock</span></div>
        <div class="vn-sr"><span>Hardware</span><span>Brushed Chrome</span></div>
      </div>
    </div>
  </div>
</section>

<!-- 9 FEATURES -->
<section class="vn-nine" id="vn-features">
  <div class="vn-nine-header vn-reveal">
    <p class="vn-label">Why Volenu</p>
    <h2 class="vn-section-title">Outstanding precision with<br>powerful features.</h2>
  </div>
  <div class="vn-nine-grid">
    <div class="vn-ni vn-reveal"><span class="vn-ni-num">01</span><h4 class="vn-ni-title">Bi-Directional Rotation</h4><p class="vn-ni-desc">CW, CCW, or alternating — programmed to match any automatic calibre's winding requirements precisely.</p></div>
    <div class="vn-ni vn-reveal vn-delay-1"><span class="vn-ni-num">02</span><h4 class="vn-ni-title">Carbon Fibre Side Panels</h4><p class="vn-ni-desc">Precision-textured carbon fibre reinforced side panels give the Quad Elite its unmistakable premium look.</p></div>
    <div class="vn-ni vn-reveal vn-delay-2"><span class="vn-ni-num">03</span><h4 class="vn-ni-title">Velvet Pillow System</h4><p class="vn-ni-desc">Every rotor is fitted with a plush black velvet pillow that cradles your watch with zero vibration and zero scratching.</p></div>
    <div class="vn-ni vn-reveal"><span class="vn-ni-num">04</span><h4 class="vn-ni-title">Programmable TPD</h4><p class="vn-ni-desc">Set turns-per-day from 650 to 1800. Each rotor pair is independently programmable for any manufacturer's spec.</p></div>
    <div class="vn-ni vn-reveal vn-delay-1"><span class="vn-ni-num">05</span><h4 class="vn-ni-title">Power Memory Function</h4><p class="vn-ni-desc">Settings are stored permanently. After any power interruption the Quad Elite automatically resumes your last configuration.</p></div>
    <div class="vn-ni vn-reveal vn-delay-2"><span class="vn-ni-num">06</span><h4 class="vn-ni-title">Overwind Protection</h4><p class="vn-ni-desc">Intelligent rest cycles prevent overwinding. The motor pauses automatically — your watch is never at risk.</p></div>
    <div class="vn-ni vn-reveal"><span class="vn-ni-num">07</span><h4 class="vn-ni-title">Display-Ready Design</h4><p class="vn-ni-desc">The full glass front panel transforms your Quad Elite into a display case. Your collection is always visible, always secured.</p></div>
    <div class="vn-ni vn-reveal vn-delay-1"><span class="vn-ni-num">08</span><h4 class="vn-ni-title">Key Lock Security</h4><p class="vn-ni-desc">Precision barrel key lock seals the full glass door. Access only on your terms — essential for serious collections.</p></div>
    <div class="vn-ni vn-reveal vn-delay-2"><span class="vn-ni-num">09</span><h4 class="vn-ni-title">Universal AC Power</h4><p class="vn-ni-desc">Global AC adapter included. 100–240V compatible — your Quad Elite works anywhere in the world.</p></div>
  </div>
</section>

<!-- CTA BOTTOM -->
<section class="vn-cta">
  <div class="vn-cta-bg">VOLENU</div>
  <p class="vn-label vn-reveal">Limited Stock Available</p>
  <h2 class="vn-cta-title vn-reveal">Your collection<br>deserves <em>this.</em></h2>
  <div class="vn-reveal" style="margin-top:8px">
    <a href="{{ routes.cart_url }}" class="vn-btn-gold">Order Now</a>
    <a href="#vn-specs" class="vn-btn-ghost">View Specs</a>
  </div>
  <p class="vn-reveal" style="margin-top:40px;font-size:12px;color:#888;letter-spacing:0.1em">Free Shipping · 30-Day Guarantee · Secure Checkout</p>
</section>

<script>
(function(){
  // Cursor
  var c=document.getElementById('vnCursor'),r=document.getElementById('vnRing');
  if(c&&r){
    document.addEventListener('mousemove',function(e){
      c.style.left=e.clientX-4+'px';c.style.top=e.clientY-4+'px';
      r.style.left=e.clientX-16+'px';r.style.top=e.clientY-16+'px';
    });
    document.querySelectorAll('a,button').forEach(function(el){
      el.addEventListener('mouseenter',function(){r.style.transform='scale(2)';r.style.borderColor='rgba(201,168,76,0.8)'});
      el.addEventListener('mouseleave',function(){r.style.transform='scale(1)';r.style.borderColor='rgba(201,168,76,0.4)'});
    });
  }
  // Scroll reveal
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('vn-visible')});
  },{threshold:0.1});
  document.querySelectorAll('.vn-reveal').forEach(function(el){obs.observe(el)});
})();
</script>

