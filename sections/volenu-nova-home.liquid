<style>
.vw-scrub-section{position:relative;height:150vh;background:#fff}
.vw-scrub-sticky{position:sticky;top:0;height:100vh;overflow:hidden;background:#111}
.vw-scrub-canvas{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.vw-scrub-text{position:absolute;left:8%;bottom:15%;color:#fff;z-index:2;transition:opacity .3s}
.vw-scrub-text h2{font-family:'EB Garamond',Georgia,serif;font-size:clamp(28px,4vw,52px);font-weight:400;line-height:1.15;margin-bottom:20px;letter-spacing:.02em}
.vw-scrub-text a{display:inline-block;border:1px solid #fff;font-family:'Raleway',sans-serif;font-size:11px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:#fff;text-decoration:none;padding:12px 36px;transition:.3s}
.vw-scrub-text a:hover{background:#fff;color:#111}
.vw-scrub-hint{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:2;text-align:center;transition:opacity .3s}
.vw-scrub-hint span{font-family:'Raleway',sans-serif;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.4);display:block;margin-bottom:8px}
.vw-scrub-hint-line{width:1px;height:36px;background:linear-gradient(rgba(255,255,255,.4),transparent);margin:0 auto;animation:vwPulse 2s infinite}
@keyframes vwPulse{0%,100%{opacity:.6}50%{opacity:.1}}
</style>
<div class="vw-scrub-section" id="vwScrub">
  <div class="vw-scrub-sticky">
    <img id="vwFrame" class="vw-scrub-canvas" src="{{ 'ezgif-frame-001.png' | asset_url }}" alt="">
    <div class="vw-scrub-text" id="vwText">
      <h2>Engineered for<br>the Exceptional.</h2>
      <a href="/collections/all">Shop the Collection</a>
    </div>
    <div class="vw-scrub-hint" id="vwHint">
      <span>Scroll to reveal</span>
      <div class="vw-scrub-hint-line"></div>
    </div>
  </div>
</div>
<script>
(function(){
  var TOTAL = 217;
  var section = document.getElementById('vwScrub');
  var img = document.getElementById('vwFrame');
  var text = document.getElementById('vwText');
  var hint = document.getElementById('vwHint');
  if(!section || !img) return;

  var baseUrl = {{ 'ezgif-frame-001.png' | asset_url | json }};
  function pad(n){ return n < 10 ? '00'+n : n < 100 ? '0'+n : ''+n; }
  function frameUrl(n){ return baseUrl.replace('ezgif-frame-001','ezgif-frame-'+pad(n)); }

  // Preload all frames
  var cache = {};
  for(var i=1;i<=TOTAL;i++){
    cache[i] = new Image();
    cache[i].src = frameUrl(i);
  }

  var currentF = 1.0;   // what's drawn
  var targetF  = 1.0;   // where scroll says we should be
  var lastDrawn = 0;

  function getScrollProgress(){
    var scrollTop = window.pageYOffset;
    var sectionTop = section.offsetTop;
    var maxScroll  = section.offsetHeight - window.innerHeight;
    var scrolled   = Math.max(0, Math.min(maxScroll, scrollTop - sectionTop));
    return maxScroll > 0 ? scrolled / maxScroll : 0;
  }

  window.addEventListener('scroll', function(){
    var p = getScrollProgress();
    targetF = 1 + p * (TOTAL - 1);
  }, {passive: true});

  function tick(){
    // Lerp — 0.08 = Nova-style smooth lag
    currentF += (targetF - currentF) * 0.08;

    var idx = Math.min(TOTAL, Math.max(1, Math.round(currentF)));
    if(idx !== lastDrawn && cache[idx] && cache[idx].complete){
      img.src = cache[idx].src;
      lastDrawn = idx;
    }

    var p = (currentF - 1) / (TOTAL - 1);
    if(text) text.style.opacity = Math.max(0, 1 - p * 4);
    if(hint) hint.style.opacity = Math.max(0, 1 - p * 10);

    requestAnimationFrame(tick);
  }

  tick();
})();
</script>

