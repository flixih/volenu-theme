<script>
(function(){
  window.addEventListener('load',function(){
    var bold='VOLENU', light='Cases';
    var bEl=document.getElementById('vnLBold');
    var sEl=document.getElementById('vnLSep');
    var lEl=document.getElementById('vnLLight');
    var cur=document.getElementById('vnLCursor');
    var loader=document.getElementById('vnLoader');
    var bi=0, li=0, charDelay=90;

    // Step 1: cursor blinks alone for 400ms
    setTimeout(function typeBold(){
      if(!bEl)return;
      if(bi < bold.length){
        bEl.textContent = bold.slice(0,bi+1);
        bi++;
        setTimeout(typeBold, charDelay);
      } else {
        // show separator, move cursor after it
        setTimeout(function(){
          sEl.style.opacity='1';
          // insert cursor after sep
          setTimeout(typeLight, 120);
        }, 80);
      }
    }, 400);

    function typeLight(){
      if(!lEl)return;
      if(li < light.length){
        lEl.textContent = light.slice(0,li+1);
        li++;
        setTimeout(typeLight, charDelay+10);
      } else {
        // done - hide cursor, wait, slide out
        setTimeout(function(){
          if(cur) cur.style.animation='none';
          if(cur) cur.style.opacity='0';
          setTimeout(function(){
            if(loader) loader.classList.add('out');
          }, 600);
        }, 350);
      }
    }
  });
  var cx=0,cy=0,rx=0,ry=0,raf;
  var c=document.getElementById('vnC'),r=document.getElementById('vnR');
  document.addEventListener('mousemove',function(e){cx=e.clientX;cy=e.clientY;if(c){c.style.left=cx+'px';c.style.top=cy+'px'}});
  function loop(){if(r){rx+=(cx-rx)*.11;ry+=(cy-ry)*.11;r.style.left=rx+'px';r.style.top=ry+'px'}requestAnimationFrame(loop)}
  loop();
  document.querySelectorAll('a,button').forEach(function(el){
    el.addEventListener('mouseenter',function(){if(r)r.classList.add('hov')});
    el.addEventListener('mouseleave',function(){if(r)r.classList.remove('hov')});
  });
  var io=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('on')})},{threshold:0.07});
  document.querySelectorAll('.vn-r').forEach(function(el){io.observe(el)});
})();
</script>

