<!-- ── NEW ARRIVALS ──────────────────────── -->
<section class="ts-section" id="new-arrivals">
  <div style="max-width:1300px;margin:0 auto">
    <div class="ts-section-center ts-reveal">
      <h2 class="ts-h2">New Arrivals</h2>
    </div>
    <div class="ts-prod-grid">
      {% assign new_products = collections.all.products | limit: 4 %}
      {% for product in new_products %}
      <div class="ts-prod-card ts-reveal ts-d{{ forloop.index }}">
        <a href="{{ product.url }}" style="text-decoration:none;color:inherit">
          <div class="ts-prod-img">
            {% if product.images.first %}
            <img src="{{ product.images.first | img_url: '600x600' }}" alt="{{ product.title }}" loading="lazy">
            {% else %}
            <img src="{{ 'winder-front.png' | asset_url }}" alt="{{ product.title }}">
            {% endif %}
            <span class="ts-badge ts-badge-new">New</span>
          </div>
          <div class="ts-prod-name">{{ product.title | upcase | truncate: 40 }}</div>
          <div class="ts-prod-price">
            {% if product.compare_at_price > product.price %}
            <span class="ts-prod-price-sale">{{ product.price | money }}</span>
            <span class="ts-prod-price-og">{{ product.compare_at_price | money }}</span>
            {% else %}
            {{ product.price | money }}
            {% endif %}
          </div>
        </a>
      </div>
      {% endfor %}
    </div>
    <div class="ts-section-center">
      <a href="/collections/all" class="ts-btn ts-reveal">View All Products</a>
    </div>
  </div>
</section>

