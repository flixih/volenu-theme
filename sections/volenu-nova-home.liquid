<script>
window.addEventListener('load',function(){
  setTimeout(function(){var l=document.getElementById('vnLoader');if(l)l.classList.add('out');},3100);
  var io=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting)x.target.classList.add('on')})},{threshold:0.07});
  document.querySelectorAll('.ts-reveal').forEach(function(el){io.observe(el)});
});
</script>

