<script>
  // Filter pills
  function vpFilter(btn, filter) {
    document.querySelectorAll('.vp-pill').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');

    // Update hero label
    const labels = {
      'all': 'ALL PRODUCTS',
      'best-sellers': 'BEST SELLERS',
      'watch-winders': 'WATCH WINDERS',
      'watch-cases': 'WATCH CASES',
      'new-arrivals': 'NEW ARRIVALS',
      'accessories': 'ACCESSORIES'
    };
    document.getElementById('vp-hero-label').textContent = labels[filter] || 'ALL PRODUCTS';

    // Filter cards
    document.querySelectorAll('.vp-card').forEach(card => {
      if (filter === 'all') {
        card.style.display = '';
      } else {
        const tags = (card.dataset.tags || '').toLowerCase();
        card.style.display = tags.includes(filter) ? '' : 'none';
      }
    });
  }

  // Sort
  function vpSort(value) {
    const grid = document.getElementById('vp-grid');
    const cards = Array.from(grid.querySelectorAll('.vp-card'));
    cards.sort((a, b) => {
      if (value === 'price-asc') return (parseInt(a.dataset.price) || 0) - (parseInt(b.dataset.price) || 0);
      if (value === 'price-desc') return (parseInt(b.dataset.price) || 0) - (parseInt(a.dataset.price) || 0);
      return 0;
    });
    cards.forEach(c => grid.appendChild(c));
  }

  // Quick add to cart
  function vpAddToCart(variantId) {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    }).then(() => {
      const count = document.getElementById('vp-cart-count');
      if (count) count.textContent = parseInt(count.textContent || 0) + 1;
    });
  }

  // Announcement bar rotation
  const msgs = [
    'SPRING/SUMMER SALE — FREE SHIPPING ON ORDERS OVER $75',
    '30-DAY MONEY BACK GUARANTEE — SHOP WITH CONFIDENCE',
    'NEW ARRIVALS: QUAD ELITE WATCH WINDER — SHOP NOW'
  ];
  let msgIdx = 0;
  const announceTxt = document.querySelector('.vp-announce span');
  document.querySelector('.vp-announce-arr.right').addEventListener('click', () => {
    msgIdx = (msgIdx + 1) % msgs.length;
    announceTxt.textContent = msgs[msgIdx];
  });
  document.querySelector('.vp-announce-arr.left').addEventListener('click', () => {
    msgIdx = (msgIdx - 1 + msgs.length) % msgs.length;
    announceTxt.textContent = msgs[msgIdx];
  });
</script>

