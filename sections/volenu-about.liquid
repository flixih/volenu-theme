<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

/* ── HERO ── */
.vab-hero {
  position: relative;
  width: 100%; height: 100vh; min-height: 600px;
  overflow: hidden;
  display: flex; align-items: flex-end;
}
.vab-hero-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%; object-fit: cover;
  object-position: center 20%;
}
.vab-hero-mobile { display: none; }
.vab-hero-desktop { display: block; }
@media (max-width: 768px) {
  .vab-hero-desktop { display: none; }
  .vab-hero-mobile { display: block; }
}
.vab-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
}
.vab-hero-content {
  position: relative; z-index: 2;
  padding: 0 56px 72px;
  color: #fff;
}
.vab-hero-eyebrow {
  font-size: 10px; letter-spacing: 0.3em;
  text-transform: uppercase; color: rgba(255,255,255,0.5);
  margin-bottom: 16px;
}
.vab-hero-title {
  font-size: clamp(48px, 7vw, 96px);
  font-weight: 700; line-height: 1;
  letter-spacing: -0.02em;
}
.vab-hero-sub {
  margin-top: 20px;
  font-size: 14px; color: rgba(255,255,255,0.6);
  letter-spacing: 0.06em; max-width: 420px;
  line-height: 1.7;
}

/* ── MANIFESTO ── */
.vab-manifesto {
  padding: 96px 56px;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center;
  border-bottom: 1px solid #ececec;
  background: #fff;
}
.vab-manifesto-img {
  width: 100%; aspect-ratio: 4/3;
  object-fit: cover; border-radius: 4px;
  display: block;
}
.vab-manifesto-right {}
.vab-manifesto-label {
  font-size: 9px; letter-spacing: 0.3em;
  text-transform: uppercase; color: #aaa;
  margin-bottom: 24px;
}
.vab-manifesto-text {
  font-size: clamp(22px, 2.6vw, 36px);
  line-height: 1.4; font-weight: 600;
  letter-spacing: -0.01em; color: #111;
}

/* ── STORY SPLIT ── */
.vab-story {
  display: grid; grid-template-columns: 1fr 1fr;
  min-height: 720px;
}
.vab-story-img-wrap {
  position: relative; overflow: hidden;
}
.vab-story-img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  display: block;
}
.vab-story-text {
  padding: 80px 64px;
  display: flex; flex-direction: column; justify-content: center;
  background: #fff;
}
.vab-story-label {
  font-size: 9px; letter-spacing: 0.3em;
  text-transform: uppercase; color: #aaa;
  margin-bottom: 28px;
}
.vab-story-title {
  font-size: clamp(28px, 3vw, 44px);
  font-weight: 700; line-height: 1.15;
  letter-spacing: -0.02em; color: #111;
  margin-bottom: 28px;
}
.vab-story-body {
  font-size: 14px; color: #555;
  line-height: 1.85; letter-spacing: 0.02em;
}
.vab-story-body p + p { margin-top: 18px; }
.vab-story-sig {
  margin-top: 40px;
  font-size: 13px; color: #111;
  letter-spacing: 0.06em; font-weight: 600;
}
.vab-story-sig span {
  display: block; font-size: 11px;
  color: #999; font-weight: 400;
  letter-spacing: 0.1em; margin-top: 4px;
}

/* ── VALUES ── */
.vab-values {
  padding: 96px 56px;
  background: #f8f8f6;
}
.vab-values-head {
  text-align: center; margin-bottom: 64px;
}
.vab-values-label {
  font-size: 9px; letter-spacing: 0.3em;
  text-transform: uppercase; color: #aaa;
  margin-bottom: 16px;
}
.vab-values-title {
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 700; letter-spacing: -0.02em; color: #111;
}
.vab-values-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.vab-value-card {
  background: #fff;
  padding: 48px 40px;
  opacity: 0; transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.vab-value-card.visible { opacity: 1; transform: translateY(0); }
.vab-value-card:nth-child(2) { transition-delay: 0.1s; }
.vab-value-card:nth-child(3) { transition-delay: 0.2s; }
.vab-value-num {
  font-size: 11px; letter-spacing: 0.2em;
  color: #ccc; margin-bottom: 20px;
}
.vab-value-title {
  font-size: 18px; font-weight: 700;
  letter-spacing: -0.01em; color: #111;
  margin-bottom: 14px;
}
.vab-value-body {
  font-size: 13px; color: #777;
  line-height: 1.8; letter-spacing: 0.02em;
}

/* ── FULL WIDTH QUOTE ── */
.vab-quote {
  padding: 120px 56px;
  text-align: center; background: #111; color: #fff;
}
.vab-quote-mark {
  font-size: 80px; line-height: 0.5;
  color: rgba(255,255,255,0.1); margin-bottom: 40px;
  font-family: Georgia, serif;
}
.vab-quote-text {
  font-size: clamp(22px, 3vw, 40px);
  font-weight: 600; line-height: 1.3;
  letter-spacing: -0.01em; max-width: 820px;
  margin: 0 auto 36px;
}
.vab-quote-attr {
  font-size: 11px; letter-spacing: 0.2em;
  color: rgba(255,255,255,0.4); text-transform: uppercase;
}

/* ── SECOND STORY SPLIT (reversed) ── */
.vab-story--reverse {
  direction: rtl;
}
.vab-story--reverse > * { direction: ltr; }
.vab-story--reverse .vab-story-text {
  background: #f8f8f6;
}

/* ── STATS ── */
.vab-stats {
  padding: 96px 56px;
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 2px; border-top: 1px solid #ececec;
  background: #fff;
}
.vab-stat {
  text-align: center; padding: 48px 24px;
  background: #fff;
  opacity: 0; transform: translateY(16px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.vab-stat.visible { opacity: 1; transform: translateY(0); }
.vab-stat:nth-child(2) { transition-delay: 0.08s; }
.vab-stat:nth-child(3) { transition-delay: 0.16s; }
.vab-stat:nth-child(4) { transition-delay: 0.24s; }
.vab-stat-num {
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 800; letter-spacing: -0.03em; color: #111;
  line-height: 1;
}
.vab-stat-label {
  font-size: 10px; letter-spacing: 0.2em;
  color: #aaa; text-transform: uppercase;
  margin-top: 10px;
}

/* ── CTA ── */
.vab-cta {
  padding: 96px 56px;
  text-align: center;
  background: #fff;
  border-top: 1px solid #ececec;
}
.vab-cta-label {
  font-size: 9px; letter-spacing: 0.3em;
  color: #aaa; text-transform: uppercase;
  margin-bottom: 20px;
}
.vab-cta-title {
  font-size: clamp(32px, 4vw, 56px);
  font-weight: 700; letter-spacing: -0.02em;
  color: #111; margin-bottom: 40px;
}
.vab-cta-btn {
  display: inline-block;
  padding: 16px 48px;
  background: #111; color: #fff;
  font-size: 11px; letter-spacing: 0.2em;
  text-transform: uppercase; text-decoration: none;
  transition: background 0.2s;
}
.vab-cta-btn:hover { background: #333; }

/* ── MOBILE ── */
@media (max-width: 768px) {
  .vab-hero-content { padding: 0 24px 48px; }
  .vab-manifesto { padding: 56px 24px; grid-template-columns: 1fr; gap: 24px; }
  .vab-manifesto-num { font-size: 72px; }
  .vab-story { grid-template-columns: 1fr; }
  .vab-story-img-wrap { height: 60vw; }
  .vab-story-text { padding: 48px 24px; }
  .vab-story--reverse { direction: ltr; }
  .vab-values { padding: 56px 24px; }
  .vab-values-grid { grid-template-columns: 1fr; gap: 2px; }
  .vab-value-card { padding: 36px 28px; }
  .vab-quote { padding: 72px 24px; }
  .vab-stats { grid-template-columns: 1fr 1fr; padding: 48px 24px; }
  .vab-cta { padding: 56px 24px; }
}
</style>

<!-- About Nav -->
<style>
.vab-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 999;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40px; height: 60px;
  transition: background 0.35s ease, color 0.35s ease;
}
.vab-nav--hero { background: transparent; }
.vab-nav--scrolled { background: #fff; border-bottom: 1px solid #ececec; }
.vab-nav-back {
  display: flex; align-items: center; gap: 8px;
  font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none; cursor: pointer;
  transition: color 0.2s;
}
.vab-nav--hero .vab-nav-back { color: rgba(255,255,255,0.75); }
.vab-nav--scrolled .vab-nav-back { color: #111; }
.vab-nav-back:hover { opacity: 0.7; }
.vab-nav-back svg { transition: transform 0.2s; }
.vab-nav-back:hover svg { transform: translateX(-3px); }
.vab-nav-logo {
  text-decoration: none;
  position: absolute; left: 50%; transform: translateX(-50%);
}
.vab-nav-logo-img {
  height: 22px; width: auto; display: block;
  transition: filter 0.35s;
}
.vab-nav--hero .vab-nav-logo-img { filter: brightness(0) invert(1); }
.vab-nav--scrolled .vab-nav-logo-img { filter: brightness(0) invert(0); }
.vab-nav-shop {
  font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none; transition: color 0.2s;
}
.vab-nav--hero .vab-nav-shop { color: rgba(255,255,255,0.75); }
.vab-nav--scrolled .vab-nav-shop { color: #111; }
.vab-nav-shop:hover { opacity: 0.7; }
@media (max-width: 768px) {
  .vab-nav { padding: 0 20px; }
}
</style>

<nav class="vab-nav vab-nav--hero" id="vab-nav">
  <a href="/" class="vab-nav-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 12H5M5 12l7-7M5 12l7 7"/></svg>
    Back
  </a>
  <a href="/" class="vab-nav-logo">
    <img src="{{ 'volenu-wordmark.png' | asset_url }}" alt="VOLENU" class="vab-nav-logo-img">
  </a>
  <a href="/collections/all" class="vab-nav-shop">Shop</a>
</nav>

<script>
(function(){
  var nav = document.getElementById('vab-nav');
  window.addEventListener('scroll', function() {
    if (window.scrollY > 80) {
      nav.classList.remove('vab-nav--hero');
      nav.classList.add('vab-nav--scrolled');
    } else {
      nav.classList.add('vab-nav--hero');
      nav.classList.remove('vab-nav--scrolled');
    }
  }, { passive: true });
})();
</script>


