    <img class="vab-story-img" src="{{ 'about-craft.jpg' | asset_url }}" alt="Volenu Craftsmanship">
  </div>
  <div class="vab-story-text">
    <div class="vab-story-label">The Craft</div>
    <h2 class="vab-story-title">Every thread chosen with purpose.</h2>
