  <a href="/collections/all" class="vab-cta-btn">Shop the Collection</a>
</section>

<script>
(function() {
  var els = document.querySelectorAll('.vab-value-card, .vab-stat, .vab-manifesto');
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.15 });
  els.forEach(function(el) { obs.observe(el); });
})();
</script>

