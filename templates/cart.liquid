{% layout 'theme' %}

<style>
.vr-cart-page {
  max-width: 1100px;
  margin: 100px auto 60px;
  padding: 0 40px;
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 48px;
}
@media (max-width: 768px) {
  .vr-cart-page { grid-template-columns: 1fr; padding: 0 20px; margin-top: 80px; }
}
.vr-cart-title {
  font-size: 11px;
  letter-spacing: 0.2em;
  font-weight: 600;
  text-transform: uppercase;
  color: #111;
  margin-bottom: 32px;
  grid-column: 1 / -1;
  padding-bottom: 16px;
  border-bottom: 1px solid #e8e8e8;
}
/* Items */
.vr-cart-items { }
.vr-cart-item {
  display: grid;
  grid-template-columns: 100px 1fr auto;
  gap: 20px;
  padding: 24px 0;
  border-bottom: 1px solid #f0f0f0;
  align-items: start;
}
.vr-cart-item img {
  width: 100px;
  height: 120px;
  object-fit: cover;
}
.vr-cart-item-name {
  font-size: 12px;
  letter-spacing: 0.1em;
  font-weight: 600;
  text-transform: uppercase;
  color: #111;
  margin-bottom: 6px;
}
.vr-cart-item-variant {
  font-size: 11px;
  color: #888;
  margin-bottom: 8px;
}
.vr-cart-item-price {
  font-size: 13px;
  color: #c0392b;
  font-weight: 600;
}
.vr-cart-item-original {
  font-size: 11px;
  color: #aaa;
  text-decoration: line-through;
  margin-left: 6px;
}
.vr-qty {
  display: flex;
  align-items: center;
  border: 1px solid #111;
  width: fit-content;
  margin-top: 12px;
}
.vr-qty button {
  width: 32px;
  height: 32px;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 16px;
  color: #111;
  display: flex;
  align-items: center;
  justify-content: center;
}
.vr-qty input {
  width: 32px;
  height: 32px;
  text-align: center;
  border-left: 1px solid #111;
  border-right: 1px solid #111;
  border-top: none;
  border-bottom: none;
  font-size: 12px;
  color: #111;
}
.vr-cart-item-total {
  font-size: 14px;
  font-weight: 600;
  color: #111;
  text-align: right;
  white-space: nowrap;
}
.vr-remove-btn {
  display: block;
  font-size: 9px;
  letter-spacing: 0.1em;
  color: #aaa;
  text-transform: uppercase;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  margin-top: 8px;
  text-align: right;
}
.vr-remove-btn:hover { color: #111; }

/* Summary */
.vr-cart-summary {
  position: sticky;
  top: 100px;
  background: #f9f9f9;
  padding: 28px;
}
.vr-summary-title {
  font-size: 11px;
  letter-spacing: 0.18em;
  font-weight: 700;
  text-transform: uppercase;
  color: #111;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 1px solid #e0e0e0;
}
.vr-summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  padding: 6px 0;
  color: #666;
}
.vr-summary-row.discount { color: #c0392b; }
.vr-summary-row.total {
  font-size: 15px;
  font-weight: 700;
  color: #111;
  border-top: 1px solid #e0e0e0;
  margin-top: 12px;
  padding-top: 16px;
}
.vr-checkout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  background: #111;
  color: #fff;
  border: none;
  padding: 16px;
  font-size: 11px;
  letter-spacing: 0.2em;
  font-weight: 700;
  text-transform: uppercase;
  cursor: pointer;
  text-decoration: none;
  margin-top: 20px;
  transition: background 0.2s;
}
.vr-checkout-btn:hover { background: #333; }
.vr-continue {
  display: block;
  text-align: center;
  font-size: 11px;
  color: #888;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  margin-top: 14px;
}
.vr-continue:hover { color: #111; }
.vr-cart-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 80px 0;
}
.vr-cart-empty h2 { font-size: 18px; font-weight: 400; color: #111; margin-bottom: 20px; }
.vr-cart-empty a {
  display: inline-block;
  background: #111;
  color: #fff;
  padding: 14px 32px;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  text-decoration: none;
}
</style>

<div class="vr-cart-page">
  <div class="vr-cart-title">Your Cart ({{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %})</div>

  {% if cart.item_count == 0 %}
    <div class="vr-cart-empty">
      <h2>Your cart is empty</h2>
      <a href="/collections/all">Continue Shopping</a>
    </div>
  {% else %}
    <div class="vr-cart-items">
      {% for item in cart.items %}
        <div class="vr-cart-item" id="cart-item-{{ item.key | replace: ':', '-' }}">
          <img src="{{ item.image | img_url: '300x' }}" alt="{{ item.title }}">
          <div>
            <div class="vr-cart-item-name">{{ item.product.title }}</div>
            <div class="vr-cart-item-variant">{{ item.variant.title }}</div>
            <div>
              <span class="vr-cart-item-price">{{ item.final_price | money }}</span>
              {% if item.variant.compare_at_price > item.variant.price %}
                <span class="vr-cart-item-original">{{ item.variant.compare_at_price | money }}</span>
              {% endif %}
            </div>
            <div class="vr-qty">
              <button onclick="vrUpdateQty('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
              <input type="number" value="{{ item.quantity }}" min="0" onchange="vrUpdateQty('{{ item.key }}', this.value)">
              <button onclick="vrUpdateQty('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
            </div>
          </div>
          <div>
            <div class="vr-cart-item-total">{{ item.final_line_price | money }}</div>
            <button class="vr-remove-btn" onclick="vrUpdateQty('{{ item.key }}', 0)">Remove</button>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Summary -->
    {%- assign orig = 0 -%}
    {%- for item in cart.items -%}
      {%- if item.variant.compare_at_price > item.variant.price -%}
        {%- assign item_orig = item.variant.compare_at_price | times: item.quantity -%}
      {%- else -%}
        {%- assign item_orig = item.original_line_price -%}
      {%- endif -%}
      {%- assign orig = orig | plus: item_orig -%}
    {%- endfor -%}
    {%- assign saved = orig | minus: cart.total_price -%}

    <div class="vr-cart-summary">
      <div class="vr-summary-title">Order Summary</div>
      <div class="vr-summary-row"><span>Subtotal</span><span style="text-decoration:line-through;color:#aaa;">{{ orig | money }}</span></div>
      {% if saved > 0 %}
        <div class="vr-summary-row discount"><span>Discount (You saved)</span><span>-{{ saved | money }}</span></div>
      {% endif %}
      <div class="vr-summary-row"><span>Shipping</span><span>{% if cart.total_price >= 10000 %}Free{% else %}Calculated at checkout{% endif %}</span></div>
      <div class="vr-summary-row total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
      <a href="/checkout" class="vr-checkout-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        Checkout Securely
      </a>
      <a href="/collections/all" class="vr-continue">← Continue Shopping</a>
    </div>
  {% endif %}
</div>

{% if cart.item_count > 0 %}
<!-- You May Also Like -->
{%- assign cart_product_ids = cart.items | map: 'product_id' -%}
<div style="max-width:1100px;margin:60px auto 80px;padding:0 40px;">
  <div style="font-size:11px;letter-spacing:0.2em;font-weight:700;text-transform:uppercase;color:#111;margin-bottom:32px;padding-bottom:14px;border-bottom:1px solid #e8e8e8;">You May Also Like</div>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;" id="vr-upsell-grid">
    {% assign shown = 0 %}
    {% for product in collections.all.products %}
      {% unless cart_product_ids contains product.id %}
        {% if shown < 4 %}
          <div style="text-align:left;">
            <a href="{{ product.url }}" style="text-decoration:none;display:block;">
              <div style="aspect-ratio:3/4;overflow:hidden;background:#f5f5f5;margin-bottom:12px;">
                <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title }}" style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'">
              </div>
              <div style="font-size:11px;letter-spacing:0.1em;font-weight:600;color:#111;text-transform:uppercase;margin-bottom:4px;">{{ product.title }}</div>
              <div style="font-size:13px;color:#c0392b;font-weight:600;">
                {{ product.price | money }}
                {% if product.compare_at_price > product.price %}
                  <span style="color:#aaa;text-decoration:line-through;font-weight:400;margin-left:6px;">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </a>
            <button onclick="vrAddUpsell({{ product.variants.first.id }}, this)" style="width:100%;margin-top:10px;padding:10px;background:#111;color:#fff;border:none;font-size:10px;letter-spacing:0.16em;font-weight:600;text-transform:uppercase;cursor:pointer;transition:background 0.2s;" onmouseover="this.style.background='#333'" onmouseout="this.style.background='#111'">+ Add to Cart</button>
          </div>
          {% assign shown = shown | plus: 1 %}
        {% endif %}
      {% endunless %}
    {% endfor %}
  </div>
</div>
{% endif %}

<script>
function vrUpdateQty(key, qty) {
  qty = parseInt(qty);
  if (isNaN(qty) || qty < 0) qty = 0;
  fetch('/cart/change.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: key, quantity: qty })
  }).then(() => location.reload());
}

function vrAddUpsell(variantId, btn) {
  btn.textContent = 'Adding...';
  btn.disabled = true;
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: variantId, quantity: 1 })
  }).then(() => {
    btn.textContent = '✓ Added!';
    btn.style.background = '#2a7a2a';
    setTimeout(() => location.reload(), 800);
  });
}
</script>
